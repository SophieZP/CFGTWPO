---
import Layout from '../../layouts/Layout.astro';
---

<Layout>
<div class="cat-page">

  <!-- HEADER -->
  <header class="cat-header">
    <div class="cat-header-inner">
      <a href="/" class="cat-logo">
        <div class="cat-logo-icon"></div>
        <div class="cat-logo-div"></div>
        <span>CFG TWPO</span>
      </a>

      <div class="cat-search-wrap">
        <svg class="cat-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" placeholder="Buscar partes, marcas o SKU..." class="cat-search-input" />
      </div>

      <nav class="cat-nav">
        <a href="/">Home</a>
        <a href="/catalog" class="active">Catálogo</a>
        <a href="/catalog">New Arrivals</a>
        <a href="#">Support</a>
      </nav>

      <div class="cat-header-actions">
        <button class="cat-cart-btn" aria-label="Carrito">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <span class="cat-cart-badge">3</span>
        </button>
        <button class="cat-mobile-btn" id="catFilterToggle" aria-label="Filtros">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="12" y1="18" x2="12" y2="18"/></svg>
          Filtros
        </button>
      </div>
    </div>
  </header>

  <div class="cat-layout">

    <!-- SIDEBAR -->
    <aside class="cat-sidebar" id="catSidebar">
      <div class="cat-sidebar-inner">

        <!-- Sidebar header -->
        <div class="cat-filter-header">
          <div class="cat-filter-title">
            <div class="cat-filter-icon"></div>
            <span>Filtros</span>
          </div>
          <button class="cat-reset">RESET</button>
        </div>

        <!-- Category -->
        <div class="cat-filter-group">
          <h3 class="cat-filter-label">Categoría</h3>
          <div class="cat-checkboxes">
            <label class="cat-check-item">
              <input type="checkbox"> <span>Engine Components</span>
            </label>
            <label class="cat-check-item cat-check-active">
              <input type="checkbox" checked> <span>Exhaust Systems</span>
            </label>
            <label class="cat-check-item">
              <input type="checkbox"> <span>Suspension</span>
            </label>
            <label class="cat-check-item">
              <input type="checkbox"> <span>Braking</span>
            </label>
            <label class="cat-check-item">
              <input type="checkbox"> <span>Interior</span>
            </label>
          </div>
        </div>

        <!-- Price Range -->
        <div class="cat-filter-group">
          <h3 class="cat-filter-label">Rango de Precio</h3>
          <input type="range" min="50" max="5000" value="2500" class="cat-range" />
          <div class="cat-range-labels">
            <span>$50</span>
            <span>$5000+</span>
          </div>
        </div>

        <!-- Brand -->
        <div class="cat-filter-group">
          <h3 class="cat-filter-label">Marca</h3>
          <div class="cat-brands">
            <label class="cat-brand-item">
              <span>CFG Performance</span>
              <input type="radio" name="brand" class="cat-radio">
            </label>
            <label class="cat-brand-item cat-brand-active">
              <span>TwPo Racing</span>
              <input type="radio" name="brand" class="cat-radio cat-radio-active" checked>
            </label>
          </div>
        </div>

        <!-- Compatibility -->
        <div class="cat-filter-group">
          <h3 class="cat-filter-label">Compatibilidad</h3>
          <select class="cat-select">
            <option value="">Select Year</option>
            <option>2023</option>
            <option>2022</option>
            <option>2021</option>
          </select>
          <select class="cat-select">
            <option value="">Select Model</option>
            <option>Sport 500</option>
            <option>Track 600</option>
          </select>
        </div>

      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="cat-main">

      <!-- Breadcrumb + Sort -->
      <div class="cat-topbar">
        <div class="cat-breadcrumb">
          <a href="/catalog">Catálogo</a>
          <span>/</span>
          <span>Performance Exhausts</span>
        </div>
        <div class="cat-sort">
          <span class="cat-sort-label">Sort by:</span>
          <select class="cat-sort-select">
            <option>Relevance</option>
            <option>Price: Low to High</option>
            <option>Price: High to Low</option>
            <option>Rating</option>
          </select>
        </div>
      </div>

      <!-- Results count -->
      <p class="cat-results">
        Showing <strong>12</strong> results for <em>"TwPo Racing"</em>
      </p>

      <!-- Products grid -->
      <div class="cat-grid">

        <!-- Card 1 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #1a1200, #0d0900);"></div>
            <span class="cat-tag cat-tag-green">In Stock</span>
          </div>
          <div class="cat-card-body">
            <h3>Titanium X-Pipe Exhaust</h3>
            <p>TwPo Racing • Series 500</p>
            <div class="cat-card-footer">
              <span class="cat-price">$1,299.00</span>
              <div class="cat-stars">★★★★☆</div>
            </div>
          </div>
        </a>

        <!-- Card 2 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #0a1020, #060b18);"></div>
            <span class="cat-tag cat-tag-green">In Stock</span>
          </div>
          <div class="cat-card-body">
            <h3>Coilover Kit Pro</h3>
            <p>CFG Performance • Track Ready</p>
            <div class="cat-card-footer">
              <span class="cat-price">$2,450.00</span>
              <div class="cat-stars">★★★★★</div>
            </div>
          </div>
        </a>

        <!-- Card 3 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #1a1a1a, #0a0a0a);"></div>
            <span class="cat-tag cat-tag-red">Pre-Order</span>
          </div>
          <div class="cat-card-body">
            <h3>Carbon Fiber Steering Wheel</h3>
            <p>TwPo Racing • Interior</p>
            <div class="cat-card-footer">
              <span class="cat-price">$899.00</span>
              <div class="cat-stars">★★★★☆</div>
            </div>
          </div>
        </a>

        <!-- Card 4 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #0d1a0d, #070d07);"></div>
            <span class="cat-tag cat-tag-green">In Stock</span>
          </div>
          <div class="cat-card-body">
            <h3>Monoblock Forged Wheels 19"</h3>
            <p>CFG Performance • 19 Inch</p>
            <div class="cat-card-footer">
              <span class="cat-price">$3,200.00</span>
              <div class="cat-stars">★★★☆☆</div>
            </div>
          </div>
        </a>

        <!-- Card 5 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #101018, #08080f);"></div>
            <span class="cat-tag cat-tag-green">In Stock</span>
          </div>
          <div class="cat-card-body">
            <h3>Digital Racing Dashboard</h3>
            <p>TwPo Racing • Electronics</p>
            <div class="cat-card-footer">
              <span class="cat-price">$1,850.00</span>
              <div class="cat-stars">★★★★★</div>
            </div>
          </div>
        </a>

        <!-- Card 6 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #1a1000, #0d0800);"></div>
            <span class="cat-tag cat-tag-gray">Low Stock</span>
          </div>
          <div class="cat-card-body">
            <h3>Stage 2 Turbocharger Kit</h3>
            <p>CFG Performance • Induction</p>
            <div class="cat-card-footer">
              <span class="cat-price">$2,100.00</span>
              <div class="cat-stars">★★★★★</div>
            </div>
          </div>
        </a>

        <!-- Card 7 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #1a0a0a, #0d0505);"></div>
            <span class="cat-tag cat-tag-green">In Stock</span>
          </div>
          <div class="cat-card-body">
            <h3>High-Flow Intake Manifold</h3>
            <p>TwPo Racing • Engine</p>
            <div class="cat-card-footer">
              <span class="cat-price">$680.00</span>
              <div class="cat-stars">★★★★☆</div>
            </div>
          </div>
        </a>

        <!-- Card 8 -->
        <a href="/product" class="cat-card">
          <div class="cat-card-img">
            <div class="cat-card-bg" style="background: linear-gradient(135deg, #0a100a, #060a06);"></div>
            <span class="cat-tag cat-tag-green">In Stock</span>
          </div>
          <div class="cat-card-body">
            <h3>Carbon Brake Caliper Set</h3>
            <p>CFG Performance • Braking</p>
            <div class="cat-card-footer">
              <span class="cat-price">$1,120.00</span>
              <div class="cat-stars">★★★★★</div>
            </div>
          </div>
        </a>

      </div>

      <!-- Pagination -->
      <nav class="cat-pagination" aria-label="Paginación">
        <button class="cat-page-btn" aria-label="Anterior">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15,18 9,12 15,6"/></svg>
        </button>
        <button class="cat-page-btn cat-page-active">1</button>
        <button class="cat-page-btn">2</button>
        <button class="cat-page-btn">3</button>
        <span class="cat-page-ellipsis">…</span>
        <button class="cat-page-btn">8</button>
        <button class="cat-page-btn" aria-label="Siguiente">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,18 15,12 9,6"/></svg>
        </button>
      </nav>

    </main>
  </div>

</div>

<script>
  const toggle = document.getElementById('catFilterToggle');
  const sidebar = document.getElementById('catSidebar');
  toggle?.addEventListener('click', () => sidebar?.classList.toggle('cat-sidebar-open'));
</script>
</Layout>

<style>
  .cat-page { min-height: 100vh; background: #111; color: #fff; font-family: 'Space Grotesk', sans-serif; }

  /* ── HEADER ── */
  .cat-header { background: #000; border-bottom: 1px solid rgba(255,255,255,.08); position: sticky; top: 0; z-index: 100; }
  .cat-header-inner { max-width: 1600px; margin: 0 auto; padding: .75rem 1.5rem; display: flex; align-items: center; gap: 1rem; flex-wrap: nowrap; }
  .cat-logo { display: flex; align-items: center; gap: .5rem; text-decoration: none; color: #fff; font-size: 1rem; font-weight: 700; letter-spacing: .06em; flex-shrink: 0; }
  .cat-logo-icon { width: 22px; height: 16px; background: #DF201A; clip-path: polygon(10% 0,90% 0,100% 100%,0 100%); }
  .cat-logo-div { width: 1px; height: 20px; background: rgba(255,255,255,.2); transform: rotate(12deg); }
  .cat-search-wrap { display: flex; align-items: center; gap: .5rem; background: #1a1a1a; border: 1px solid rgba(255,255,255,.1); border-radius: 8px; padding: .5rem .75rem; flex: 1; max-width: 380px; }
  .cat-search-icon { width: 14px; height: 14px; color: rgba(255,255,255,.4); flex-shrink: 0; }
  .cat-search-input { background: none; border: none; outline: none; color: #fff; font-family: inherit; font-size: .82rem; width: 100%; min-width: 0; }
  .cat-search-input::placeholder { color: rgba(255,255,255,.3); }
  .cat-nav { display: flex; gap: 1.5rem; flex: 1; }
  .cat-nav a { font-size: .8rem; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: rgba(255,255,255,.5); text-decoration: none; transition: color .15s; white-space: nowrap; }
  .cat-nav a:hover, .cat-nav a.active { color: #DF201A; }
  .cat-header-actions { display: flex; align-items: center; gap: .75rem; margin-left: auto; }
  .cat-cart-btn { position: relative; background: none; border: none; cursor: pointer; padding: .5rem; color: #fff; }
  .cat-cart-btn svg { width: 20px; height: 20px; }
  .cat-cart-badge { position: absolute; top: 0; right: 0; width: 16px; height: 16px; background: #DF201A; border-radius: 50%; font-size: .6rem; font-weight: 700; display: flex; align-items: center; justify-content: center; }
  .cat-mobile-btn { display: none; align-items: center; gap: .4rem; background: rgba(255,255,255,.08); border: 1px solid rgba(255,255,255,.15); color: #fff; padding: .45rem .85rem; border-radius: 6px; font-family: inherit; font-size: .78rem; font-weight: 600; cursor: pointer; white-space: nowrap; }
  .cat-mobile-btn svg { width: 16px; height: 16px; }

  /* ── LAYOUT ── */
  .cat-layout { display: flex; max-width: 1600px; margin: 0 auto; min-height: calc(100vh - 56px); }

  /* ── SIDEBAR ── */
  .cat-sidebar { width: 272px; flex-shrink: 0; background: #000; border-right: 1px solid rgba(255,255,255,.07); }
  .cat-sidebar-inner { padding: 1.5rem; display: flex; flex-direction: column; gap: 2rem; position: sticky; top: 56px; max-height: calc(100vh - 56px); overflow-y: auto; }
  .cat-filter-header { display: flex; justify-content: space-between; align-items: center; }
  .cat-filter-title { display: flex; align-items: center; gap: .5rem; font-size: 1rem; font-weight: 700; color: #fff; }
  .cat-filter-icon { width: 14px; height: 10px; background: #DF201A; clip-path: polygon(20% 0,80% 0,100% 100%,0 100%); }
  .cat-reset { background: none; border: none; cursor: pointer; font-family: inherit; font-size: .7rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: rgba(255,255,255,.35); transition: color .15s; }
  .cat-reset:hover { color: #fff; }
  .cat-filter-group { display: flex; flex-direction: column; gap: .75rem; }
  .cat-filter-label { font-size: .7rem; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.5); }
  .cat-checkboxes { display: flex; flex-direction: column; gap: .4rem; }
  .cat-check-item { display: flex; align-items: center; gap: .65rem; cursor: pointer; font-size: .85rem; color: rgba(255,255,255,.5); transition: color .15s; }
  .cat-check-item:hover { color: #fff; }
  .cat-check-item input { width: 14px; height: 14px; accent-color: #DF201A; cursor: pointer; }
  .cat-check-active { color: rgba(255,255,255,.85) !important; }
  .cat-range { width: 100%; accent-color: #DF201A; cursor: pointer; }
  .cat-range-labels { display: flex; justify-content: space-between; font-size: .72rem; color: #E39B1D; margin-top: .25rem; }
  .cat-brands { display: flex; flex-direction: column; gap: .5rem; }
  .cat-brand-item { display: flex; align-items: center; justify-content: space-between; padding: .6rem .75rem; background: #1a1a1a; border-radius: 4px; cursor: pointer; font-size: .85rem; color: rgba(255,255,255,.6); border: 1px solid transparent; transition: border-color .15s; }
  .cat-brand-active { border-color: rgba(223,32,26,.4) !important; box-shadow: 0 0 10px rgba(223,32,26,.1); color: #fff !important; }
  .cat-radio { width: 14px; height: 14px; accent-color: #DF201A; cursor: pointer; }
  .cat-select { width: 100%; background: #1a1a1a; border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: #fff; font-family: inherit; font-size: .82rem; padding: .55rem .75rem; outline: none; cursor: pointer; }
  .cat-select:focus { border-color: rgba(223,32,26,.4); }

  /* ── MAIN ── */
  .cat-main { flex: 1; padding: clamp(1.5rem,3vw,2.5rem) clamp(1rem,2vw,2rem); min-width: 0; }
  .cat-topbar { display: flex; justify-content: space-between; align-items: center; padding-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,.07); margin-bottom: .75rem; flex-wrap: wrap; gap: .75rem; }
  .cat-breadcrumb { display: flex; align-items: center; gap: .4rem; font-size: .82rem; }
  .cat-breadcrumb a { color: rgba(255,255,255,.4); text-decoration: none; }
  .cat-breadcrumb a:hover { color: #fff; }
  .cat-breadcrumb span { color: rgba(255,255,255,.2); }
  .cat-breadcrumb span:last-child { color: #fff; }
  .cat-sort { display: flex; align-items: center; gap: .5rem; font-size: .82rem; }
  .cat-sort-label { color: rgba(255,255,255,.4); white-space: nowrap; }
  .cat-sort-select { background: transparent; border: none; color: #fff; font-family: inherit; font-size: .82rem; font-weight: 700; outline: none; cursor: pointer; }
  .cat-results { font-size: .82rem; color: rgba(255,255,255,.4); margin-bottom: 1.5rem; }
  .cat-results strong { color: #fff; }
  .cat-results em { color: #fff; font-style: normal; }

  /* ── PRODUCTS GRID ── */
  .cat-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(min(100%, 200px), 1fr)); gap: 1rem; margin-bottom: 2.5rem; }
  .cat-card { display: flex; flex-direction: column; background: #000; border: 1px solid rgba(255,255,255,.08); border-radius: 10px; overflow: hidden; text-decoration: none; color: inherit; transition: border-color .2s, transform .2s; }
  .cat-card:hover { border-color: rgba(255,255,255,.2); transform: translateY(-3px); }
  .cat-card-img { position: relative; aspect-ratio: 1; overflow: hidden; }
  .cat-card-bg { position: absolute; inset: 0; }
  .cat-tag { position: absolute; top: .65rem; left: .65rem; font-size: .58rem; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; padding: .18rem .5rem; border-radius: 3px; backdrop-filter: blur(4px); }
  .cat-tag-green { background: rgba(0,0,0,.6); border: 1px solid rgba(30,216,56,.8); color: #1ED838; }
  .cat-tag-red { background: rgba(0,0,0,.6); border: 1px solid rgba(223,32,26,.8); color: #DF201A; }
  .cat-tag-gray { background: rgba(0,0,0,.6); border: 1px solid rgba(255,255,255,.3); color: rgba(255,255,255,.6); }
  .cat-card-body { padding: 1rem; display: flex; flex-direction: column; gap: .3rem; flex: 1; }
  .cat-card-body h3 { font-size: .88rem; font-weight: 700; color: #fff; line-height: 1.3; }
  .cat-card-body p { font-size: .72rem; color: rgba(255,255,255,.35); }
  .cat-card-footer { display: flex; align-items: center; justify-content: space-between; margin-top: auto; padding-top: .5rem; gap: .5rem; flex-wrap: wrap; }
  .cat-price { font-size: .95rem; font-weight: 800; color: #E39B1D; white-space: nowrap; }
  .cat-stars { color: #E39B1D; font-size: .7rem; white-space: nowrap; }

  /* ── PAGINATION ── */
  .cat-pagination { display: flex; align-items: center; justify-content: center; gap: .35rem; flex-wrap: wrap; padding-bottom: 1rem; }
  .cat-page-btn { width: 38px; height: 38px; display: flex; align-items: center; justify-content: center; background: #1a1a1a; border: 1px solid rgba(255,255,255,.12); border-radius: 8px; color: rgba(255,255,255,.6); font-family: inherit; font-size: .85rem; font-weight: 600; cursor: pointer; transition: background .15s, color .15s; }
  .cat-page-btn svg { width: 14px; height: 14px; }
  .cat-page-btn:hover { background: rgba(255,255,255,.1); color: #fff; }
  .cat-page-active { background: #DF201A !important; border-color: #DF201A !important; color: #fff !important; }
  .cat-page-ellipsis { color: rgba(255,255,255,.3); padding: 0 .25rem; font-size: .85rem; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .cat-nav { display: none; }
    .cat-search-wrap { max-width: 240px; }
    .cat-mobile-btn { display: flex; }
    .cat-sidebar { position: fixed; top: 56px; left: -280px; z-index: 200; width: 272px; height: calc(100vh - 56px); transition: left .25s; overflow-y: auto; }
    .cat-sidebar-open { left: 0 !important; }
    .cat-layout { display: block; }
    .cat-main { padding: 1.25rem 1rem; }
  }
  @media (max-width: 600px) {
    .cat-search-wrap { display: none; }
    .cat-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 360px) {
    .cat-grid { grid-template-columns: 1fr; }
  }
</style>