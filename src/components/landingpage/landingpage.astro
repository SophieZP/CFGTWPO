---
import Layout from '../../layouts/Layout.astro';
import bgImage from '../../assets/Background+Image-005.jpg';
import engineImage from '../../assets/Engine block assembly-012.jpg';
import suspensionImage from '../../assets/Suspension Kit-016.jpg';
import exhaustImage from '../../assets/Titanium Exhaust Tip-015.jpg';
import wheelImage from '../../assets/Alloy Wheel-018.jpg';
import turboImage from '../../assets/Turbocharger-008.jpg';
import brakeImage from '../../assets/Brake disc rotor-007.jpg';
import helmetImage from '../../assets/Motorcycle helmet-009.jpg';
import sparkImage from '../../assets/Spark plugs-010.jpg';
---

<Layout>
<div class="lp">

  <!-- HEADER -->
  <header class="lp-header">
    <div class="lp-header-inner">
      <!-- Logo -->
      <a href="/" class="lp-logo">
        <div class="logo-icon"></div>
        <div class="logo-div"></div>
        <span class="logo-text">CFG TWPO</span>
      </a>

      <!-- Nav (desktop) -->
      <nav class="lp-nav">
        <a href="/" class="lp-nav-link">Inicio</a>
        <a href="/catalog" class="lp-nav-link">Catálogo</a>
        <a href="/catalog" class="lp-nav-link">Motos</a>
        <a href="/catalog" class="lp-nav-link">Carros</a>
        <a href="/catalog" class="lp-nav-link">Accesorios</a>
      </nav>

      <!-- Actions -->
      <div class="lp-actions">
        <div class="lp-search">
          <svg class="lp-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" placeholder="Buscar..." class="lp-search-input" />
        </div>
        <button class="lp-btn-login">Log In</button>
        <a href="/catalog" class="lp-btn-cart">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <span>Carrito (0)</span>
        </a>
        <!-- Mobile menu button -->
        <button class="lp-mobile-menu" id="mobileMenuBtn" aria-label="Menú">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>

    <!-- Mobile nav -->
    <nav class="lp-mobile-nav" id="mobileNav">
      <a href="/">Inicio</a>
      <a href="/catalog">Catálogo</a>
      <a href="/catalog">Motos</a>
      <a href="/catalog">Carros</a>
      <a href="/catalog">Accesorios</a>
    </nav>
  </header>

  <!-- HERO -->
  <section class="lp-hero">
    <div class="lp-hero-bg"><img src={bgImage.src} alt="Hero Background" /></div>
    <div class="lp-hero-grad"></div>
    <div class="lp-hero-inner">
      <div class="lp-hero-content">
        <!-- Badge -->
        <div class="lp-badge">
          <span class="lp-badge-dot"></span>
          <span>DISTRIBUIDOR OFICIAL</span>
        </div>

        <!-- Heading -->
        <h1 class="lp-hero-title">
          <span class="lp-h1-white">máximo</span>
          <span class="lp-h1-red">rendimiento</span>
          <span class="lp-h1-white lp-h1-small">para cada máquina</span>
        </h1>

        <!-- Subtitle -->
        <div class="lp-hero-sub">
          <p>El catálogo de <strong>CFG Parts</strong> y <strong>TwPo Racing</strong>. Componentes diseñados para la calle y el circuito.</p>
        </div>

        <!-- CTAs -->
        <div class="lp-hero-ctas">
          <a href="/catalog" class="lp-cta-primary">
            Comprar para Motos
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
          </a>
          <a href="/catalog" class="lp-cta-secondary">
            Repuestos para Carros
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="lp-section">
    <div class="lp-container">
      <div class="lp-section-header">
        <h2 class="lp-section-title">
          <span class="t-white">EXPLORAR </span><span class="t-dim">CATEGORÍAS</span>
        </h2>
        <a href="/catalog" class="lp-view-all">
          Ver Todo
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,18 15,12 9,6"/></svg>
        </a>
      </div>

      <div class="lp-cats">
        <a href="/catalog" class="lp-cat">
          <div class="lp-cat-img"><img src={engineImage.src} alt="Motor" /></div>
          <div class="lp-cat-overlay">
            <p class="lp-cat-title">MOTOR</p>
            <p class="lp-cat-sub">COMPONENTES</p>
          </div>
        </a>
        <a href="/catalog" class="lp-cat">
          <div class="lp-cat-img"><img src={suspensionImage.src} alt="Suspensión" /></div>
          <div class="lp-cat-overlay">
            <p class="lp-cat-title">SUSPENSIÓN</p>
            <p class="lp-cat-sub">FRENOS Y AMORTIGUADORES</p>
          </div>
        </a>
        <a href="/catalog" class="lp-cat">
          <div class="lp-cat-img"><img src={exhaustImage.src} alt="Escape" /></div>
          <div class="lp-cat-overlay">
            <p class="lp-cat-title">ESCAPE</p>
            <p class="lp-cat-sub">SISTEMAS COMPLETOS</p>
          </div>
        </a>
        <a href="/catalog" class="lp-cat">
          <div class="lp-cat-img"><img src={wheelImage.src} alt="Ruedas" /></div>
          <div class="lp-cat-overlay">
            <p class="lp-cat-title">RUEDAS</p>
            <p class="lp-cat-sub">LLANTAS Y RINES</p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- FEATURED PRODUCTS -->
  <section class="lp-section lp-section-dark">
    <div class="lp-container">
      <div class="lp-section-header">
        <div>
          <h2 class="lp-section-title t-white">PIEZAS DESTACADAS</h2>
          <p class="lp-section-sub">Mejores calificaciones de esta semana</p>
        </div>
        <a href="/catalog" class="lp-view-all">Ver Todo <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9,18 15,12 9,6"/></svg></a>
      </div>

      <div class="lp-products">

        <a href="/products/ceramic-rotor-kit" class="lp-product">
          <div class="lp-product-img">
            <div class="lp-product-img-inner"><img src={brakeImage.src} alt="Carbon Ceramic Rotor Kit" /></div>
            <span class="lp-stock lp-stock-green">Disponible</span>
          </div>
          <div class="lp-product-info">
            <div class="lp-stars">★★★★★ <span>(4.8)</span></div>
            <h3>Carbon Ceramic Rotor Kit</h3>
            <p>Kit de discos de freno de carbono-cerámica</p>
            <div class="lp-product-footer">
              <span class="lp-price">$450.00</span>
              <button class="lp-add-btn" aria-label="Agregar al carrito">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              </button>
            </div>
          </div>
        </a>

        <a href="/products/turbo-t4" class="lp-product">
          <div class="lp-product-img">
            <div class="lp-product-img-inner"><img src={turboImage.src} alt="Twin-Scroll Turbo T4" /></div>
            <span class="lp-stock lp-stock-green">Disponible</span>
          </div>
          <div class="lp-product-info">
            <div class="lp-stars">★★★★★ <span>(5.0)</span></div>
            <h3>Twin-Scroll Turbo T4</h3>
            <p>Turbo de doble entrada T4</p>
            <div class="lp-product-footer">
              <span class="lp-price">$1,299.00</span>
              <button class="lp-add-btn" aria-label="Agregar al carrito">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              </button>
            </div>
          </div>
        </a>

        <a href="/products/aero-carbon-helmet" class="lp-product lp-product-sold">
          <div class="lp-product-img">
            <div class="lp-product-img-inner lp-img-dim"><img src={helmetImage.src} alt="Aero Carbon Helmet" /></div>
            <span class="lp-stock lp-stock-gray">Agotado</span>
          </div>
          <div class="lp-product-info">
            <div class="lp-stars lp-stars-dim">★★★★☆ <span>(4.2)</span></div>
            <h3 class="t-dim">Aero Carbon Helmet</h3>
            <p>Casco de carbono aerodinámico</p>
            <div class="lp-product-footer">
              <span class="lp-price lp-price-strike">$350.00</span>
              <button class="lp-add-btn lp-add-btn-disabled" aria-label="No disponible" disabled>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              </button>
            </div>
          </div>
        </a>

        <a href="/products/spark-plugs" class="lp-product">
          <div class="lp-product-img">
            <div class="lp-product-img-inner"><img src={sparkImage.src} alt="Iridium Spark Plugs" /></div>
            <span class="lp-stock lp-stock-green">Disponible</span>
          </div>
          <div class="lp-product-info">
            <div class="lp-stars">★★★★★ <span>(5.0)</span></div>
            <h3>Iridium Spark Plugs (4-Pack)</h3>
            <p>Bujías de iridio</p>
            <div class="lp-product-footer">
              <span class="lp-price">$85.99</span>
              <button class="lp-add-btn" aria-label="Agregar al carrito">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
              </button>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="lp-footer">
    <div class="lp-container">
      <div class="lp-footer-grid">

        <div class="lp-footer-brand">
          <div class="lp-logo">
            <div class="logo-icon"></div>
            <div class="logo-div"></div>
            <span class="logo-text">CFG TWPO</span>
          </div>
          <p>Importer &amp; Distributor</p>
        </div>

        <div class="lp-footer-col">
          <h4>Shop</h4>
          <a href="/catalog">Motocicletas</a>
          <a href="/catalog">Carros</a>
          <a href="/catalog">Accesorios</a>
          <a href="/catalog">Estrenos</a>
        </div>

        <div class="lp-footer-col">
          <h4>Support</h4>
          <a href="#">Rastreo de pedido</a>
          <a href="#">Devoluciones</a>
          <a href="#">Envíos</a>
          <a href="/stadistics">Estadísticas</a>
          <a href="#">Contacto</a>
        </div>

        <div class="lp-footer-col">
          <h4>Newsletter</h4>
          <p class="lp-footer-newsletter-desc">Únete para ofertas exclusivas y lanzamientos de productos</p>
          <div class="lp-newsletter">
            <input type="email" placeholder="Tu correo" />
            <button>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12,5 19,12 12,19"/></svg>
            </button>
          </div>
        </div>

      </div>

      <div class="lp-footer-bottom">
        <span>© 2024 CFG TWPO. Todos los derechos reservados.</span>
        <div class="lp-social">
          <a href="#" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="#" aria-label="YouTube">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.45A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.97C5.12 20 12 20 12 20s6.88 0 8.59-.45a2.78 2.78 0 0 0 1.95-1.97A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75,15.02 15.5,12 9.75,8.98 9.75,15.02" fill="currentColor" stroke="none"/></svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

</div>

<script>
  const btn = document.getElementById('mobileMenuBtn');
  const nav = document.getElementById('mobileNav');
  btn?.addEventListener('click', () => nav?.classList.toggle('open'));
</script>
</Layout>

<style>
  .lp { min-height: 100vh; background: #0d0d0d; color: #fff; font-family: 'Space Grotesk', sans-serif; }
  .t-white { color: #fff; }
  .t-dim { color: rgba(255,255,255,.45); }

  /* ── HEADER ── */
  .lp-header { background: #000; border-bottom: 1px solid rgba(255,255,255,.08); position: sticky; top: 0; z-index: 100; }
  .lp-header-inner { max-width: 1400px; margin: 0 auto; padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 1.5rem; flex-wrap: nowrap; }
  .lp-logo { display: flex; align-items: center; gap: .6rem; text-decoration: none; flex-shrink: 0; }
  .logo-icon { width: 24px; height: 18px; background: #DF201A; clip-path: polygon(10% 0,90% 0,100% 100%,0 100%); }
  .logo-div { width: 1px; height: 22px; background: rgba(255,255,255,.2); transform: rotate(12deg); }
  .logo-text { font-size: 1rem; font-weight: 700; letter-spacing: .06em; color: #fff; }
  .lp-nav { display: flex; align-items: center; gap: 1.5rem; flex: 1; }
  .lp-nav-link { font-size: .82rem; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; color: rgba(255,255,255,.5); text-decoration: none; transition: color .15s; white-space: nowrap; }
  .lp-nav-link:hover { color: #fff; }
  .lp-actions { display: flex; align-items: center; gap: .75rem; margin-left: auto; }
  .lp-search { display: flex; align-items: center; gap: .5rem; background: #1a1a1a; border: 1px solid rgba(255,255,255,.1); border-radius: 8px; padding: .5rem .75rem; min-width: 0; }
  .lp-search-icon { width: 14px; height: 14px; color: rgba(255,255,255,.4); flex-shrink: 0; }
  .lp-search-input { background: none; border: none; outline: none; color: #fff; font-family: inherit; font-size: .82rem; width: clamp(80px, 15vw, 160px); }
  .lp-search-input::placeholder { color: rgba(255,255,255,.3); }
  .lp-btn-login { background: none; border: 1px solid rgba(255,255,255,.2); color: rgba(255,255,255,.6); padding: .45rem 1rem; border-radius: 999px; font-family: inherit; font-size: .75rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; cursor: pointer; white-space: nowrap; transition: border-color .15s, color .15s; }
  .lp-btn-login:hover { border-color: rgba(255,255,255,.5); color: #fff; }
  .lp-btn-cart { display: flex; align-items: center; gap: .4rem; background: #DF201A; color: #fff; padding: .45rem 1rem; border-radius: 999px; font-size: .75rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; text-decoration: none; white-space: nowrap; box-shadow: 0 0 15px rgba(223,32,26,.3); transition: background .15s; }
  .lp-btn-cart:hover { background: #c01b15; }
  .lp-btn-cart svg { width: 14px; height: 14px; }
  .lp-mobile-menu { display: none; flex-direction: column; gap: 4px; background: none; border: none; cursor: pointer; padding: .4rem; }
  .lp-mobile-menu span { display: block; width: 20px; height: 2px; background: #fff; border-radius: 1px; }
  .lp-mobile-nav { display: none; padding: 1rem 1.5rem; border-top: 1px solid rgba(255,255,255,.08); flex-direction: column; gap: .25rem; background: #000; }
  .lp-mobile-nav a { display: block; padding: .6rem .5rem; font-size: .9rem; font-weight: 600; color: rgba(255,255,255,.6); text-decoration: none; border-radius: 6px; transition: background .15s, color .15s; }
  .lp-mobile-nav a:hover { background: rgba(255,255,255,.05); color: #fff; }
  .lp-mobile-nav.open { display: flex; }

  /* ── HERO ── */
  .lp-hero { position: relative; overflow: hidden; min-height: clamp(400px, 60vh, 680px); display: flex; align-items: center; }
  .lp-hero-bg { position: absolute; inset: 0; background: linear-gradient(135deg, #0a0a0a 0%, #111 60%, #1a0a08 100%); }
  .lp-hero-bg img { width: 100%; height: 100%; object-fit: cover; opacity: 0.4; }
  .lp-hero-grad { position: absolute; inset: 0; background: radial-gradient(ellipse 60% 80% at 70% 50%, rgba(223,32,26,.08) 0%, transparent 70%); }
  .lp-hero-inner { max-width: 1400px; width: 100%; margin: 0 auto; padding: clamp(3rem,8vw,6rem) 1.5rem; position: relative; z-index: 1; }
  .lp-hero-content { max-width: 720px; }
  .lp-badge { display: inline-flex; align-items: center; gap: .4rem; font-size: .65rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: rgba(255,255,255,.5); background: rgba(0,0,0,.7); border: 1px solid rgba(227,155,29,.3); border-radius: 999px; padding: .3rem .85rem; margin-bottom: 1.5rem; backdrop-filter: blur(4px); }
  .lp-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #1ED838; box-shadow: 0 0 6px #1ED838; }
  .lp-hero-title { font-size: clamp(3rem,10vw,7rem); font-weight: 700; line-height: 0.95; letter-spacing: -.02em; text-transform: uppercase; margin-bottom: 1.5rem; display: flex; flex-direction: column; gap: .05em; }
  .lp-h1-white { color: #fff; text-shadow: 0 2px 4px rgba(0,0,0,.3); }
  .lp-h1-red { color: #DF201A; text-shadow: 0 2px 10px rgba(223,32,26,.5); }
  .lp-h1-small { font-size: clamp(1.6rem,5vw,3.5rem); color: rgba(255,255,255,.8); }
  .lp-hero-sub { border-left: 4px solid #E39B1D; padding-left: 1rem; margin-bottom: 2rem; max-width: 540px; }
  .lp-hero-sub p { font-size: clamp(.9rem,2vw,1.1rem); color: rgba(255,255,255,.55); line-height: 1.6; }
  .lp-hero-sub strong { color: #fff; }
  .lp-hero-ctas { display: flex; flex-wrap: wrap; gap: .75rem; }
  .lp-cta-primary { display: inline-flex; align-items: center; gap: .5rem; padding: clamp(.75rem,2vw,1rem) clamp(1.25rem,3vw,1.75rem); background: linear-gradient(135deg, #DF201A, #c01b15); color: #fff; font-size: clamp(.85rem,1.5vw,.95rem); font-weight: 700; text-decoration: none; border-radius: 4px; box-shadow: 0 4px 20px rgba(223,32,26,.4); transition: transform .15s, box-shadow .15s; }
  .lp-cta-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(223,32,26,.5); }
  .lp-cta-primary svg { width: 16px; height: 16px; }
  .lp-cta-secondary { display: inline-flex; align-items: center; gap: .5rem; padding: clamp(.75rem,2vw,1rem) clamp(1.25rem,3vw,1.75rem); background: #000; color: #fff; font-size: clamp(.85rem,1.5vw,.95rem); font-weight: 700; text-decoration: none; border: 1px solid rgba(255,255,255,.2); border-radius: 4px; transition: border-color .15s, background .15s; }
  .lp-cta-secondary:hover { border-color: rgba(255,255,255,.5); background: rgba(255,255,255,.05); }
  .lp-cta-secondary svg { width: 16px; height: 16px; }

  /* ── SHARED SECTION ── */
  .lp-section { padding: clamp(3rem,6vw,5rem) 0; }
  .lp-section-dark { background: #000; }
  .lp-container { max-width: 1400px; margin: 0 auto; padding: 0 1.5rem; }
  .lp-section-header { display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: clamp(1.5rem,3vw,2.5rem); flex-wrap: wrap; gap: 1rem; border-left: 4px solid #DF201A; padding-left: 1rem; }
  .lp-section-title { font-size: clamp(1.2rem,3vw,1.8rem); font-weight: 700; text-transform: uppercase; letter-spacing: -.01em; }
  .lp-section-sub { font-size: .78rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: rgba(255,255,255,.35); margin-top: .3rem; }
  .lp-view-all { display: flex; align-items: center; gap: .25rem; font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #E39B1D; text-decoration: none; white-space: nowrap; transition: gap .15s; }
  .lp-view-all:hover { gap: .5rem; }
  .lp-view-all svg { width: 14px; height: 14px; }

  /* ── CATEGORIES ── */
  .lp-cats { display: grid; grid-template-columns: repeat(auto-fit, minmax(min(100%, 220px), 1fr)); gap: 1rem; }
  .lp-cat { position: relative; border-radius: 10px; overflow: hidden; border: 1px solid rgba(255,255,255,.08); text-decoration: none; display: block; aspect-ratio: 3/4; }
  @media (min-width: 768px) { .lp-cat { aspect-ratio: 1/1; } }
  .lp-cat-img { position: absolute; inset: 0; }
  .lp-cat-img img { width: 100%; height: 100%; object-fit: cover; }
  .lp-cat-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 1rem; background: linear-gradient(to top, rgba(0,0,0,.9) 0%, rgba(0,0,0,.6) 50%, transparent 100%); border-top: 1px solid rgba(255,255,255,.08); backdrop-filter: blur(2px); }
