---
---

<section class="relative min-h-[400px] md:min-h-[500px] lg:min-h-[680px] flex items-center overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0a] via-[#111] to-[#1a0a08]"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_80%_at_70%_50%,rgba(223,32,26,0.08)_0%,transparent_70%)]"></div>
  
  <!-- Content -->
  <div class="relative z-10 max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20 w-full">
    <div class="max-w-[720px]">
      
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 text-[0.65rem] font-bold tracking-[0.14em] uppercase text-white/50 bg-black/70 border border-[#E39B1D]/30 rounded-full px-3 py-1.5 mb-6 backdrop-blur-sm">
        <span class="w-1.5 h-1.5 rounded-full bg-[#1ED838] shadow-[0_0_6px_#1ED838]"></span>
        Distribuidor Oficial
      </div>

      <!-- Title -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[0.95] tracking-tight uppercase mb-6">
        <span class="text-white block">máximo</span>
        <span class="text-[#DF201A] block">rendimiento</span>
        <span class="text-white/80 text-2xl sm:text-3xl md:text-4xl lg:text-5xl block">para cada máquina</span>
      </h1>

      <!-- Subtitle -->
      <div class="border-l-4 border-[#E39B1D] pl-4 mb-8 max-w-[540px]">
        <p class="text-sm sm:text-base text-white/55 leading-relaxed">
          El catálogo de <strong class="text-white">CFG Parts</strong> y <strong class="text-white">TwPo Racing</strong>. Componentes diseñados para la calle y el circuito.
        </p>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3">
        <a 
          href="/catalog?category=motorcycles" 
          data-prefetch
          class="inline-flex items-center gap-2 px-5 py-3 bg-gradient-to-br from-[#DF201A] to-[#c01b15] text-white text-sm font-bold rounded shadow-[0_4px_20px_rgba(223,32,26,0.4)] hover:shadow-[0_8px_30px_rgba(223,32,26,0.5)] hover:-translate-y-0.5 transition-all duration-150"
        >
          Comprar para Motos
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12,5 19,12 12,19"/>
          </svg>
        </a>
        <a 
          href="/catalog?category=cars" 
          data-prefetch
          class="inline-flex items-center gap-2 px-5 py-3 bg-black text-white text-sm font-bold rounded border border-white/20 hover:border-white/50 hover:bg-white/5 transition-all duration-150"
        >
          Repuestos para Carros
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12,5 19,12 12,19"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>
