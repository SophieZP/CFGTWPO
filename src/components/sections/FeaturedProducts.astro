---
import brakeImage from '../../assets/Brake disc rotor-007.jpg';
import turboImage from '../../assets/Turbocharger-008.jpg';
import helmetImage from '../../assets/Motorcycle helmet-009.jpg';
import sparkImage from '../../assets/Spark plugs-010.jpg';

const products = [
  {
    id: 'ceramic-rotor-kit',
    image: brakeImage,
    name: 'Carbon Ceramic Rotor Kit',
    description: 'Kit de discos de freno de carbono-cerámica',
    price: 450.00,
    rating: 4.8,
    stock: 'available',
    brand: 'CFG Performance',
  },
  {
    id: 'turbo-t4',
    image: turboImage,
    name: 'Twin-Scroll Turbo T4',
    description: 'Turbo de doble entrada T4',
    price: 1299.00,
    rating: 5.0,
    stock: 'available',
    brand: 'TwPo Racing',
  },
  {
    id: 'aero-carbon-helmet',
    image: helmetImage,
    name: 'Aero Carbon Helmet',
    description: 'Casco de carbono aerodinámico',
    price: 350.00,
    rating: 4.2,
    stock: 'soldout',
    brand: 'TwPo Racing',
  },
  {
    id: 'spark-plugs',
    image: sparkImage,
    name: 'Iridium Spark Plugs (4-Pack)',
    description: 'Bujías de iridio',
    price: 85.99,
    rating: 5.0,
    stock: 'available',
    brand: 'CFG Performance',
  },
];

const formatPrice = (price: number) => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
  }).format(price);
};

const getStockClass = (stock: string) => {
  switch (stock) {
    case 'available':
      return 'bg-[#1ED838] text-black';
    case 'soldout':
      return 'bg-white/15 text-white/70';
    case 'lowstock':
      return 'bg-[#DF201A] text-white';
    default:
      return 'bg-white/15 text-white/70';
  }
};

const getStockText = (stock: string) => {
  switch (stock) {
    case 'available':
      return 'Disponible';
    case 'soldout':
      return 'Agotado';
    case 'lowstock':
      return 'Poco stock';
    default:
      return 'Disponible';
  }
};
---

<section class="py-12 md:py-16 lg:py-20 bg-black">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6 md:mb-10 border-l-4 border-[#DF201A] pl-4">
      <div>
        <h2 class="text-xl md:text-2xl lg:text-3xl font-bold uppercase tracking-tight text-white">
          Piezas Destacadas
        </h2>
        <p class="text-xs sm:text-sm font-bold uppercase tracking-wider text-white/35 mt-1">
          Mejores calificaciones de esta semana
        </p>
      </div>
      <a 
        href="/catalog" 
        class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-[#E39B1D] hover:gap-2 transition-all"
      >
        Ver Todo
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9,18 15,12 9,6"/>
        </svg>
      </a>
    </div>

    <!-- Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
      {products.map((product) => (
        <a 
          href={`/product/${product.id}`}
          data-prefetch
          class:list={[
            'group flex flex-col bg-[#0d0d0d] border border-white/08 rounded-lg overflow-hidden hover:border-white/20 hover:-translate-y-1 transition-all duration-200',
            product.stock === 'soldout' && 'opacity-70'
          ]}
        >
          <!-- Image -->
          <div class="relative aspect-[4/3] overflow-hidden">
            <img 
              src={product.image.src} 
              alt={product.name}
              class:list={[
                'w-full h-full object-cover transition-transform duration-300',
                product.stock === 'soldout' && 'opacity-50',
                'group-hover:scale-105'
              ]}
            />
            <!-- Stock Badge -->
            <span class:list={[
              'absolute top-3 left-3 text-[0.6rem] font-bold uppercase tracking-wider px-2 py-1 rounded',
              getStockClass(product.stock)
            ]}>
              {getStockText(product.stock)}
            </span>
          </div>

          <!-- Info -->
          <div class="p-4 flex flex-col flex-1">
            <!-- Rating -->
            <div class="flex items-center gap-1 mb-2">
              <span class="text-[#E39B1D] text-xs">
                {'★'.repeat(Math.floor(product.rating))}
                {'☆'.repeat(5 - Math.floor(product.rating))}
              </span>
              <span class="text-white/35 text-xs">({product.rating})</span>
            </div>

            <!-- Title -->
            <h3 class:list={[
              'text-sm font-bold leading-tight mb-1',
              product.stock === 'soldout' ? 'text-white/45' : 'text-white'
            ]}>
              {product.name}
            </h3>

            <!-- Description -->
            <p class="text-xs text-white/40 mb-3 flex-1">
              {product.description}
            </p>

            <!-- Footer -->
            <div class="flex items-center justify-between pt-3 border-t border-white/08">
              <span class="text-base font-extrabold text-white">
                {formatPrice(product.price)}
              </span>
              <button 
                class:list={[
                  'w-9 h-9 flex items-center justify-center rounded-md border transition-colors',
                  product.stock === 'soldout'
                    ? 'bg-white/08 border-white/15 opacity-30 cursor-not-allowed'
                    : 'bg-white/08 border-white/15 hover:bg-[#DF201A] hover:border-[#DF201A]'
                ]}
                aria-label="Agregar al carrito"
                disabled={product.stock === 'soldout'}
              >
                <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
              </button>
            </div>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
