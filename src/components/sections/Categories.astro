---
import engineImage from '../../assets/Engine block assembly-012.jpg';
import suspensionImage from '../../assets/Suspension Kit-016.jpg';
import exhaustImage from '../../assets/Titanium Exhaust Tip-015.jpg';
import wheelImage from '../../assets/Alloy Wheel-018.jpg';

const categories = [
  {
    image: engineImage,
    title: 'MOTOR',
    subtitle: 'COMPONENTES',
    href: '/catalog?category=engine',
  },
  {
    image: suspensionImage,
    title: 'SUSPENSIÓN',
    subtitle: 'FRENOS Y AMORTIGUADORES',
    href: '/catalog?category=suspension',
  },
  {
    image: exhaustImage,
    title: 'ESCAPE',
    subtitle: 'SISTEMAS COMPLETOS',
    href: '/catalog?category=exhaust',
  },
  {
    image: wheelImage,
    title: 'RUEDAS',
    subtitle: 'LLANTAS Y RINES',
    href: '/catalog?category=wheels',
  },
];
---

<section class="py-12 md:py-16 lg:py-20">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Section Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-6 md:mb-10 border-l-4 border-[#DF201A] pl-4">
      <h2 class="text-xl md:text-2xl lg:text-3xl font-bold uppercase tracking-tight">
        <span class="text-white">Explorar </span>
        <span class="text-white/45">Categorías</span>
      </h2>
      <a 
        href="/catalog" 
        class="inline-flex items-center gap-1 text-xs font-bold uppercase tracking-wider text-[#E39B1D] hover:gap-2 transition-all"
      >
        Ver Todo
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="9,18 15,12 9,6"/>
        </svg>
      </a>
    </div>

    <!-- Categories Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {categories.map((cat) => (
        <a 
          href={cat.href} 
          class="group relative block aspect-[3/4] md:aspect-square rounded-lg overflow-hidden border border-white/08 hover:border-white/20 transition-all duration-200"
        >
          <!-- Image -->
          <img 
            src={cat.image.src} 
            alt={cat.title}
            class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          />
          
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
          
          <!-- Content -->
          <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-white/08 backdrop-blur-sm">
            <p class="text-sm font-bold uppercase tracking-wider text-white mb-0.5">{cat.title}</p>
            <p class="text-[0.62rem] font-bold uppercase tracking-widest text-white/40">{cat.subtitle}</p>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
