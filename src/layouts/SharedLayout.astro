---
import '../styles/global.css';
interface Props {
  title?: string;
  activePage?: string;
}
const { title = 'CFG TWPO', activePage = '' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — CFG TWPO</title>
  </head>
  <body>

    <!-- ══ SHARED HEADER ══ -->
    <header class="sh-header">
      <div class="sh-header-inner">
        <!-- Logo -->
        <a href="/" class="sh-logo">
          <div class="sh-logo-icon"></div>
          <div class="sh-logo-div"></div>
          <span>CFG TWPO</span>
        </a>

        <!-- Desktop Nav -->
        <nav class="sh-nav">
          <a href="/" class={activePage === 'home' ? 'active' : ''}>Home</a>
          <a href="/catalog" class={activePage === 'catalog' ? 'active' : ''}>Catálogo</a>
          <a href="/catalog" class={activePage === 'newarrivals' ? 'active' : ''}>New Arrivals</a>
          <a href="/stadistics" class={activePage === 'support' ? 'active' : ''}>Support</a>
        </nav>

        <!-- Actions -->
        <div class="sh-actions">
          <div class="sh-search-wrap">
            <svg class="sh-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" placeholder="Buscar partes, marcas o SKU..." class="sh-search-input" />
          </div>

          <button class="sh-cart-btn" aria-label="Carrito">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            <span class="sh-cart-badge">3</span>
          </button>

          <!-- Mobile menu -->
          <button class="sh-mobile-btn" id="shMobileBtn" aria-label="Menú">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>

      <!-- Mobile Nav -->
      <nav class="sh-mobile-nav" id="shMobileNav">
        <a href="/">Home</a>
        <a href="/catalog">Catálogo</a>
        <a href="/catalog">New Arrivals</a>
        <a href="/stadistics">Support</a>
      </nav>
    </header>

    <!-- ══ PAGE CONTENT ══ -->
    <slot />

    <!-- ══ SHARED FOOTER ══ -->
    <footer class="sh-footer">
      <div class="sh-footer-inner">
        <div class="sh-footer-grid">

          <div class="sh-footer-brand">
            <a href="/" class="sh-logo sh-footer-logo">
              <div class="sh-logo-icon"></div>
              <div class="sh-logo-div"></div>
              <span>CFG TWPO</span>
            </a>
            <p>Performance parts engineered for speed, durability, and precision. Elevate your machine with CFG TWPO.</p>
            <div class="sh-social">
              <a href="#" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="2" width="20" height="20" rx="5"/>
                  <circle cx="12" cy="12" r="5"/>
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/>
                </svg>
              </a>
              <a href="#" aria-label="Facebook">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
              </a>
              <a href="#" aria-label="YouTube">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.97C18.88 4 12 4 12 4s-6.88 0-8.59.45A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.97C5.12 20 12 20 12 20s6.88 0 8.59-.45a2.78 2.78 0 0 0 1.95-1.97A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                  <polygon points="9.75,15.02 15.5,12 9.75,8.98 9.75,15.02" fill="currentColor" stroke="none"/>
                </svg>
              </a>
            </div>
          </div>

          <div class="sh-footer-col">
            <h4>Shop</h4>
            <a href="/catalog">Motocicletas</a>
            <a href="/catalog">Carros</a>
            <a href="/catalog">Accesorios</a>
            <a href="/catalog">Estrenos</a>
          </div>

          <div class="sh-footer-col">
            <h4>Support</h4>
            <a href="#">Rastreo de pedido</a>
            <a href="#">Devoluciones y cambios</a>
            <a href="#">Información de envío</a>
            <a href="/stadistics">Estadísticas</a>
            <a href="#">Contacto</a>
          </div>

          <div class="sh-footer-col">
            <h4>Newsletter</h4>
            <p class="sh-newsletter-desc">Únete para ofertas exclusivas y lanzamientos de productos</p>
            <div class="sh-newsletter">
              <input type="email" placeholder="Tu correo electrónico" />
              <button type="button">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12,5 19,12 12,19"/>
                </svg>
              </button>
            </div>
          </div>

        </div>

        <div class="sh-footer-bottom">
          <span>© 2024 CFG TWPO Performance. Todos los derechos reservados.</span>
          <div class="sh-footer-links">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

  </body>
</html>

<script>
  const btn = document.getElementById('shMobileBtn');
  const nav = document.getElementById('shMobileNav');
  btn?.addEventListener('click', () => {
    nav?.classList.toggle('open');
    btn.classList.toggle('open');
  });
</script>

<style is:global>
  html, body { margin: 0; width: 100%; }

  /* ══ SHARED HEADER ══ */
  .sh-header {
    background: #000;
    border-bottom: 1px solid rgba(255,255,255,.08);
    position: sticky;
    top: 0;
    z-index: 200;
    font-family: 'Space Grotesk', sans-serif;
  }
  .sh-header-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: .75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .sh-logo {
    display: flex;
    align-items: center;
    gap: .55rem;
    text-decoration: none;
    flex-shrink: 0;
    color: #fff;
  }
  .sh-logo-icon {
    width: 22px;
    height: 16px;
    background: #DF201A;
    clip-path: polygon(10% 0, 90% 0, 100% 100%, 0 100%);
    flex-shrink: 0;
  }
  .sh-logo-div {
    width: 1px;
    height: 20px;
    background: rgba(255,255,255,.2);
    transform: rotate(12deg);
    flex-shrink: 0;
  }
  .sh-logo span {
    font-size: .95rem;
    font-weight: 700;
    letter-spacing: .06em;
    white-space: nowrap;
  }
  .sh-nav {
    display: flex;
    align-items: center;
    gap: 1.75rem;
    flex: 1;
  }
  .sh-nav a {
    font-size: .78rem;
    font-weight: 600;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: rgba(255,255,255,.45);
    text-decoration: none;
    transition: color .15s;
    white-space: nowrap;
  }
  .sh-nav a:hover, .sh-nav a.active { color: #DF201A; }
  .sh-actions {
    display: flex;
    align-items: center;
    gap: .75rem;
    margin-left: auto;
  }
  .sh-search-wrap {
    display: flex;
    align-items: center;
    gap: .45rem;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 8px;
    padding: .45rem .75rem;
    flex-shrink: 0;
  }
  .sh-search-icon { width: 13px; height: 13px; color: rgba(255,255,255,.35); flex-shrink: 0; }
  .sh-search-input {
    background: none;
    border: none;
    outline: none;
    color: #fff;
    font-family: inherit;
    font-size: .78rem;
    width: clamp(100px, 18vw, 220px);
  }
  .sh-search-input::placeholder { color: rgba(255,255,255,.28); }
  .sh-cart-btn {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: .45rem;
    color: #fff;
    flex-shrink: 0;
  }
  .sh-cart-btn svg { width: 19px; height: 19px; display: block; }
  .sh-cart-badge {
    position: absolute;
    top: 0;
    right: 0;
    width: 15px;
    height: 15px;
    background: #DF201A;
    border-radius: 50%;
    font-size: .58rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Grotesk', sans-serif;
  }
  .sh-mobile-btn {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: .4rem;
    flex-shrink: 0;
  }
  .sh-mobile-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: #fff;
    border-radius: 1px;
    transition: transform .2s, opacity .2s;
  }
  .sh-mobile-btn.open span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .sh-mobile-btn.open span:nth-child(2) { opacity: 0; }
  .sh-mobile-btn.open span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  .sh-mobile-nav {
    display: none;
    flex-direction: column;
    gap: .1rem;
    padding: .75rem 1.5rem 1rem;
    border-top: 1px solid rgba(255,255,255,.06);
    background: #000;
  }
  .sh-mobile-nav.open { display: flex; }
  .sh-mobile-nav a {
    display: block;
    padding: .6rem .5rem;
    font-size: .88rem;
    font-weight: 600;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    border-radius: 6px;
    font-family: 'Space Grotesk', sans-serif;
    transition: background .15s, color .15s;
  }
  .sh-mobile-nav a:hover { background: rgba(255,255,255,.05); color: #fff; }

  /* ══ SHARED FOOTER ══ */
  .sh-footer {
    background: #000;
    border-top: 1px solid rgba(255,255,255,.08);
    font-family: 'Space Grotesk', sans-serif;
  }
  .sh-footer-inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) 1.5rem 0;
  }
  .sh-footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: clamp(2rem, 4vw, 3rem);
    margin-bottom: 2.5rem;
  }
  .sh-footer-logo { margin-bottom: .75rem; }
  .sh-footer-brand > p {
    font-size: .8rem;
    color: rgba(255,255,255,.35);
    line-height: 1.6;
    max-width: 240px;
    margin-bottom: 1.25rem;
  }
  .sh-social { display: flex; gap: 1rem; }
  .sh-social a { color: rgba(255,255,255,.3); transition: color .15s; }
  .sh-social a:hover { color: #fff; }
  .sh-social svg { width: 18px; height: 18px; display: block; }
  .sh-footer-col { display: flex; flex-direction: column; gap: .5rem; }
  .sh-footer-col h4 {
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #fff;
    padding-left: .6rem;
    border-left: 2px solid #DF201A;
    margin-bottom: .4rem;
  }
  .sh-footer-col a {
    font-size: .8rem;
    color: rgba(255,255,255,.38);
    text-decoration: none;
    transition: color .15s;
  }
  .sh-footer-col a:hover { color: #fff; }
  .sh-newsletter-desc {
    font-size: .78rem;
    color: rgba(255,255,255,.38);
    line-height: 1.5;
    margin-bottom: .25rem !important;
  }
  .sh-newsletter {
    display: flex;
    border: 1px solid rgba(255,255,255,.14);
    border-radius: 4px;
    overflow: hidden;
    margin-top: .5rem;
  }
  .sh-newsletter input {
    flex: 1;
    background: #0d0d0d;
    border: none;
    outline: none;
    color: #fff;
    font-family: inherit;
    font-size: .78rem;
    padding: .6rem .75rem;
    min-width: 0;
  }
  .sh-newsletter input::placeholder { color: rgba(255,255,255,.22); }
  .sh-newsletter button {
    background: #DF201A;
    border: none;
    padding: .6rem .85rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .15s;
  }
  .sh-newsletter button:hover { background: #c01b15; }
  .sh-newsletter button svg { width: 15px; height: 15px; color: #fff; }
  .sh-footer-bottom {
    border-top: 1px solid rgba(255,255,255,.07);
    padding: 1.25rem 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: .75rem;
    font-size: .72rem;
    color: rgba(255,255,255,.28);
  }
  .sh-footer-links { display: flex; gap: 1.5rem; }
  .sh-footer-links a { color: rgba(255,255,255,.28); text-decoration: none; transition: color .15s; }
  .sh-footer-links a:hover { color: rgba(255,255,255,.6); }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 1100px) {
    .sh-footer-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 900px) {
    .sh-nav { display: none; }
    .sh-search-wrap { display: none; }
    .sh-mobile-btn { display: flex; }
  }
  @media (max-width: 600px) {
    .sh-footer-grid { grid-template-columns: 1fr; }
  }
</style>