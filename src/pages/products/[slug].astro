---
import SharedLayout from '../../layouts/SharedLayout.astro';
import pistonImage from '../../assets/Piston side view-014.jpg';
import engineImage from '../../assets/Engine block assembly-012.jpg';
import turboImage from '../../assets/Turbocharger-008.jpg';
import brakeImage from '../../assets/Brake disc rotor-007.jpg';
import products from '../../data/products.json';

export async function getStaticPaths() {
  return products.map((product: any) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;

// Map images based on product
const imageMap: Record<string, any> = {
  'piston-kit': pistonImage,
  'ceramic-rotor-kit': brakeImage,
  'turbo-t4': turboImage,
  'spark-plugs': pistonImage
};

const mainImage = imageMap[product.slug] || pistonImage;
---

<SharedLayout title={product.name} activePage="catalog">
<div class="pd-page">

  <!-- Breadcrumb -->
  <div class="pd-breadcrumb-bar">
    <div class="pd-breadcrumb-inner">
      <a href="/">Home</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,18 15,12 9,6"/></svg>
      <a href="/catalog">Engine Components</a>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9,18 15,12 9,6"/></svg>
      <span>{product.name}</span>
    </div>
  </div>

  <!-- Main product section -->
  <div class="pd-main">

    <!-- ══ LEFT: Gallery ══ -->
    <div class="pd-gallery">
      <div class="pd-gallery-main">
        <img src={mainImage.src} alt={product.name} id="pdMainImg" />
        <div class="pd-gallery-badges">
          <span class="pd-gbadge pd-gbadge-green">In Stock</span>
          <span class="pd-gbadge pd-gbadge-red">Best Seller</span>
        </div>
      </div>
      <div class="pd-thumbs">
        <button class="pd-thumb pd-thumb-active" data-img={mainImage.src} aria-label="Vista 1">
          <img src={mainImage.src} alt={product.name} />
        </button>
        <button class="pd-thumb" data-img={engineImage.src} aria-label="Vista 2">
          <img src={engineImage.src} alt="Engine component" />
        </button>
        <button class="pd-thumb" data-img={turboImage.src} aria-label="Vista 3">
          <img src={turboImage.src} alt="Turbocharger" />
        </button>
        <button class="pd-thumb pd-thumb-more" aria-label="Ver más">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M12 8v8M8 12h8"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- ══ RIGHT: Product Info ══ -->
    <div class="pd-info">

      <!-- Title + SKU + Rating -->
      <div class="pd-info-head">
        <h1 class="pd-title">{product.name}</h1>
        <div class="pd-meta-row">
          <span class="pd-sku">SKU: {product.sku}</span>
          <div class="pd-rating">
            <div class="pd-stars">
              <span>★</span><span>★</span><span>★</span><span>★</span><span>★</span>
            </div>
            <span class="pd-reviews">({product.reviews} reviews)</span>
          </div>
        </div>
      </div>

      <!-- Price + description -->
      <div class="pd-price-block">
        <div class="pd-prices">
          <span class="pd-price-current">${product.price.toFixed(2)}</span>
          <span class="pd-price-original">${product.originalPrice.toFixed(2)}</span>
          <span class="pd-price-save">Save {Math.round(((product.originalPrice - product.price) / product.originalPrice) * 100)}%</span>
        </div>
        <p class="pd-description">
          {product.description}
        </p>
      </div>

      <!-- Bore size selector -->
      <div class="pd-option-group">
        <div class="pd-option-label">Bore Size</div>
        <div class="pd-option-btns" id="boreSizeGroup">
          <button class="pd-opt-btn pd-opt-active">86mm</button>
          <button class="pd-opt-btn">86.5mm</button>
          <button class="pd-opt-btn">87mm</button>
        </div>
      </div>

      <!-- Quantity -->
      <div class="pd-option-group">
        <div class="pd-option-label">Quantity</div>
        <div class="pd-qty-wrap">
          <button class="pd-qty-btn" id="pdQtyMinus" aria-label="Restar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          </button>
          <input type="number" class="pd-qty-input" id="pdQtyInput" value="1" min="1" max="99" readonly />
          <button class="pd-qty-btn" id="pdQtyPlus" aria-label="Sumar">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- Actions -->
      <div class="pd-actions">
        <button class="pd-add-cart-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
          </svg>
          Add to Cart
        </button>
        <button class="pd-wishlist-btn" aria-label="Guardar en lista de deseos">
          <svg viewBox="0 0 0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
      </div>

      <!-- Quick policies -->
      <div class="pd-policies">
        <div class="pd-policy">
          <div class="pd-policy-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="1" y="3" width="15" height="13"/><polygon points="16,8 20,8 23,11 23,16 16,16 16,8"/>
              <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </div>
          <div>
            <div class="pd-policy-title">Free shipping over $150</div>
          </div>
        </div>
        <div class="pd-policy">
          <div class="pd-policy-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
          </div>
          <div>
            <div class="pd-policy-title">2-Year Warranty</div>
          </div>
        </div>
        <div class="pd-policy">
          <div class="pd-policy-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="1,4 1,10 7,10"/>
              <path d="M3.51 15a9 9 0 1 0 .49-4.75"/>
            </svg>
          </div>
          <div>
            <div class="pd-policy-title">30-Day Returns</div>
          </div>
        </div>
        <div class="pd-policy">
          <div class="pd-policy-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <div>
            <div class="pd-policy-title">Secure Checkout</div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ══ SECONDARY CONTENT ══ -->
  <div class="pd-secondary">

    <!-- Tech Specs -->
    <div class="pd-specs-card">
      <div class="pd-sec-header">
        <div class="pd-sec-icon"></div>
        <h3>Technical Specifications</h3>
      </div>
      <div class="pd-specs-table">
        <div class="pd-spec-row">
          <span class="pd-spec-label">Material</span>
          <span class="pd-spec-val">Forged 2618 Aluminum</span>
        </div>
        <div class="pd-spec-row">
          <span class="pd-spec-label">Compression Ratio</span>
          <span class="pd-spec-val">10.5:1</span>
        </div>
        <div class="pd-spec-row">
          <span class="pd-spec-label">Weight</span>
          <span class="pd-spec-val">295g (per piston)</span>
        </div>
        <div class="pd-spec-row">
          <span class="pd-spec-label">Coating</span>
          <span class="pd-spec-val">Moly Skirt Coating</span>
        </div>
        <div class="pd-spec-row">
          <span class="pd-spec-label">Pin Diameter</span>
          <span class="pd-spec-val">22mm</span>
        </div>
        <div class="pd-spec-row">
          <span class="pd-spec-label">Compatibility</span>
          <span class="pd-spec-val">TWPO Series Gen 2</span>
        </div>
      </div>
    </div>

    <!-- Fitment & Shipping -->
    <div class="pd-right-col">

      <!-- Vehicle Fitment -->
      <div class="pd-fitment-card">
        <div class="pd-sec-header">
          <div class="pd-sec-icon"></div>
          <h3>Vehicle Fitment</h3>
        </div>
        <p class="pd-fitment-desc">Select your vehicle to confirm compatibility with this part.</p>
        <div class="pd-fitment-selects">
          <select class="pd-select">
            <option value="">Select Year</option>
            <option>2023</option>
            <option>2022</option>
            <option>2021</option>
            <option>2020</option>
          </select>
          <select class="pd-select">
            <option value="">Select Make</option>
            <option>CFG Performance</option>
            <option>TwPo Racing</option>
          </select>
          <select class="pd-select">
            <option value="">Select Model</option>
            <option>Sport 500</option>
            <option>Track 600</option>
            <option>Gen 2 Series</option>
          </select>
        </div>
      </div>

      <!-- Shipping & Returns -->
      <div class="pd-shipping-card">
        <div class="pd-sec-header">
          <svg viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" width="18" height="18">
            <rect x="1" y="3" width="15" height="13"/>
            <polygon points="16,8 20,8 23,11 23,16 16,16 16,8"/>
            <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
          </svg>
          <h3>Shipping &amp; Returns</h3>
        </div>
        <div class="pd-shipping-list">
          <div class="pd-ship-item">
            <div class="pd-ship-dot pd-ship-dot-green"></div>
            <div>
              <div class="pd-ship-title">Fast Shipping</div>
              <div class="pd-ship-sub">Orders placed before 2PM EST ship same day.</div>
            </div>
          </div>
          <div class="pd-ship-item">
            <div class="pd-ship-dot"></div>
            <div>
              <div class="pd-ship-title">International Delivery</div>
              <div class="pd-ship-sub">We ship to over 100 countries worldwide via DHL Express.</div>
            </div>
          </div>
          <div class="pd-ship-item">
            <div class="pd-ship-dot"></div>
            <div>
              <div class="pd-ship-title">Easy Returns</div>
              <div class="pd-ship-sub">Unused parts can be returned within 30 days. Restocking fee may apply.</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ══ REVIEWS ══ -->
  <div class="pd-reviews">
    <div class="pd-reviews-header">
      <h3>Customer Reviews</h3>
      <button class="pd-write-review-btn">Write a Review</button>
    </div>
    <div class="pd-reviews-grid">
      <div class="pd-review-card">
        <div class="pd-review-stars">★★★★★</div>
        <div class="pd-review-title">Noticeable Power Gains</div>
        <p class="pd-review-body">"Installed these in my track build and the compression bump made a significant difference. Quality is top notch."</p>
        <div class="pd-reviewer">
          <div class="pd-reviewer-avatar">JD</div>
          <span>John D. • Verified Buyer</span>
        </div>
      </div>
      <div class="pd-review-card">
        <div class="pd-review-stars">★★★★★</div>
        <div class="pd-review-title">Perfect Fitment</div>
        <p class="pd-review-body">"Direct drop-in for the TWPO block. Measurements were spot on out of the box. Highly recommend."</p>
        <div class="pd-reviewer">
          <div class="pd-reviewer-avatar">MS</div>
          <span>Mike S. • Verified Buyer</span>
        </div>
      </div>
      <div class="pd-review-card">
        <div class="pd-review-stars">★★★★★</div>
        <div class="pd-review-title">Great Value</div>
        <p class="pd-review-body">"For the price point, you can't beat the CFG kit. Shipping was incredibly fast too."</p>
        <div class="pd-reviewer">
          <div class="pd-reviewer-avatar">AR</div>
          <span>Alex R. • Verified Buyer</span>
        </div>
      </div>
    </div>
  </div>

</div>
</SharedLayout>

<script>
  // Gallery thumbnail switcher
  const mainImg = document.getElementById('pdMainImg') as HTMLImageElement;
  document.querySelectorAll('.pd-thumb[data-img]').forEach(btn => {
    btn.addEventListener('click', () => {
      const src = btn.getAttribute('data-img');
      if (src && mainImg) mainImg.src = src;
      document.querySelectorAll('.pd-thumb').forEach(b => b.classList.remove('pd-thumb-active'));
      btn.classList.add('pd-thumb-active');
    });
  });

  // Bore size selector
  document.querySelectorAll('#boreSizeGroup .pd-opt-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#boreSizeGroup .pd-opt-btn').forEach(b => b.classList.remove('pd-opt-active'));
      btn.classList.add('pd-opt-active');
    });
  });

  // Quantity
  const qtyInput = document.getElementById('pdQtyInput') as HTMLInputElement;
  document.getElementById('pdQtyMinus')?.addEventListener('click', () => {
    const v = parseInt(qtyInput.value);
    if (v > 1) qtyInput.value = String(v - 1);
  });
  document.getElementById('pdQtyPlus')?.addEventListener('click', () => {
    const v = parseInt(qtyInput.value);
    if (v < 99) qtyInput.value = String(v + 1);
  });
</script>

<style>
  .pd-page {
    background: #111;
    min-height: calc(100vh - 57px);
    font-family: 'Space Grotesk', sans-serif;
    color: #fff;
  }

  /* Breadcrumb */
  .pd-breadcrumb-bar {
    border-bottom: 1px solid rgba(255,255,255,.06);
    background: rgba(0,0,0,.3);
  }
  .pd-breadcrumb-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: .75rem 2.5rem;
    display: flex;
    align-items: center;
    gap: .4rem;
    font-size: .82rem;
    flex-wrap: wrap;
  }
  .pd-breadcrumb-inner a { color: rgba(255,255,255,.4); text-decoration: none; transition: color .15s; }
  .pd-breadcrumb-inner a:hover { color: #fff; }
  .pd-breadcrumb-inner svg { width: 14px; height: 14px; color: rgba(255,255,255,.25); flex-shrink: 0; }
  .pd-breadcrumb-inner span { color: #fff; }

  /* Main layout */
  .pd-main {
    max-width: 1280px;
    margin: 0 auto;
    padding: 2.5rem 2.5rem 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }
  @media (max-width: 900px) { .pd-main { grid-template-columns: 1fr; gap: 2rem; } }

  /* Gallery */
  .pd-gallery { display: flex; flex-direction: column; gap: 1rem; }
  .pd-gallery-main {
    position: relative;
    aspect-ratio: 4/3;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.08);
    border-radius: 12px;
    overflow: hidden;
  }
  .pd-gallery-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity .3s;
  }
  .pd-gallery-badges { position: absolute; top: 1rem; left: 1rem; display: flex; gap: .5rem; }
  .pd-gbadge {
    font-size: .65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: .25rem .6rem;
    border-radius: 4px;
  }
  .pd-gbadge-green { background: #1ED838; color: #000; }
  .pd-gbadge-red { background: #DF201A; color: #fff; }
  .pd-thumbs { display: flex; gap: .75rem; }
  .pd-thumb {
    flex: 1;
    aspect-ratio: 1;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid rgba(255,255,255,.08);
    cursor: pointer;
    background: #1a1a1a;
    transition: border-color .15s;
    padding: .2rem;
  }
  .pd-thumb img { width: 100%; height: 100%; object-fit: cover; border-radius: 6px; }
  .pd-thumb:hover { border-color: rgba(255,255,255,.3); }
  .pd-thumb-active { border-color: #DF201A !important; }
  .pd-thumb-more {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,.4);
    background: #1a1a1a;
  }
  .pd-thumb-more svg { width: 22px; height: 22px; }

  /* Info */
  .pd-info { display: flex; flex-direction: column; gap: 1.5rem; }
  .pd-info-head { display: flex; flex-direction: column; gap: .75rem; }
  .pd-title { font-size: clamp(1.75rem, 3.5vw, 2.75rem); font-weight: 700; line-height: 1.1; letter-spacing: -.02em; }
  .pd-meta-row { display: flex; align-items: center; gap: 1.25rem; flex-wrap: wrap; }
  .pd-sku { font-size: .8rem; color: rgba(255,255,255,.4); }
  .pd-rating { display: flex; align-items: center; gap: .4rem; }
  .pd-stars { color: #E39B1D; font-size: .85rem; letter-spacing: .05em; }
  .pd-reviews { font-size: .82rem; color: rgba(255,255,255,.45); }

  .pd-price-block { border-top: 1px solid rgba(255,255,255,.07); border-bottom: 1px solid rgba(255,255,255,.07); padding: 1.25rem 0; display: flex; flex-direction: column; gap: .85rem; }
  .pd-prices { display: flex; align-items: baseline; gap: .75rem; flex-wrap: wrap; }
  .pd-price-current { font-size: 2rem; font-weight: 800; color: #E39B1D; }
  .pd-price-original { font-size: 1.1rem; color: rgba(255,255,255,.35); text-decoration: line-through; }
  .pd-price-save {
    font-size: .72rem;
    font-weight: 700;
    background: rgba(30,216,56,.15);
    color: #1ED838;
    padding: .2rem .5rem;
    border-radius: 4px;
    border: 1px solid rgba(30,216,56,.25);
  }
  .pd-description { font-size: .9rem; color: rgba(255,255,255,.6); line-height: 1.65; }

  /* Options */
  .pd-option-group { display: flex; flex-direction: column; gap: .6rem; }
  .pd-option-label { font-size: .75rem; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: rgba(255,255,255,.45); }
  .pd-option-btns { display: flex; gap: .6rem; flex-wrap: wrap; }
  .pd-opt-btn {
    padding: .5rem 1.1rem;
    background: transparent;
    border: 1px solid rgba(255,255,255,.18);
    border-radius: 4px;
    color: #fff;
    font-family: inherit;
    font-size: .9rem;
    cursor: pointer;
    transition: border-color .15s, background .15s, color .15s;
  }
  .pd-opt-btn:hover { border-color: rgba(255,255,255,.4); }
  .pd-opt-active { background: rgba(223,32,26,.1) !important; border-color: #DF201A !important; color: #DF201A !important; }

  /* Qty */
  .pd-qty-wrap {
    display: flex;
    align-items: center;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 4px;
    width: fit-content;
    overflow: hidden;
  }
  .pd-qty-btn {
    background: rgba(255,255,255,.04);
    border: none;
    width: 42px;
    height: 44px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    transition: background .15s;
  }
  .pd-qty-btn:hover { background: rgba(255,255,255,.1); }
  .pd-qty-btn svg { width: 14px; height: 14px; }
  .pd-qty-input {
    width: 56px;
    background: none;
    border: none;
    outline: none;
    color: #fff;
    text-align: center;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 600;
    border-left: 1px solid rgba(255,255,255,.15);
    border-right: 1px solid rgba(255,255,255,.15);
  }

  /* Actions */
  .pd-actions { display: flex; gap: .75rem; }
  .pd-add-cart-btn {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .6rem;
    background: #DF201A;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 1rem 1.5rem;
    font-family: inherit;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    box-shadow: 0 6px 25px rgba(223,32,26,.35);
    transition: background .15s, transform .1s;
  }
  .pd-add-cart-btn:hover { background: #c01b15; }
  .pd-add-cart-btn:active { transform: scale(.98); }
  .pd-add-cart-btn svg { width: 18px; height: 18px; flex-shrink: 0; }
  .pd-wishlist-btn {
    width: 54px;
    height: 54px;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,.5);
    transition: border-color .15s, color .15s;
    flex-shrink: 0;
  }
  .pd-wishlist-btn:hover { border-color: #DF201A; color: #DF201A; }
  .pd-wishlist-btn svg { width: 18px; height: 18px; }

  /* Policies */
  .pd-policies { display: grid; grid-template-columns: 1fr 1fr; gap: .6rem; }
  .pd-policy { display: flex; align-items: center; gap: .5rem; }
  .pd-policy-icon {
    width: 28px;
    height: 28px;
    background: rgba(223,32,26,.1);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #DF201A;
    flex-shrink: 0;
  }
  .pd-policy-icon svg { width: 13px; height: 13px; }
  .pd-policy-title { font-size: .75rem; color: rgba(255,255,255,.5); }

  /* Secondary */
  .pd-secondary {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 2.5rem 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
