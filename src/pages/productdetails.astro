---
import Layout from '../layouts/Layout.astro';
import exhaustImage from '../assets/Titanium Exhaust Tip-015.jpg';
import turboImage from '../assets/Turbocharger-008.jpg';
import pistonImage from '../assets/Piston side view-014.jpg';
---

<Layout>
  <div class="pd-page">
    <!-- Header -->
    <header class="pd-header">
      <div class="pd-header-inner">
        <a href="/" class="pd-logo">
          <div class="pd-logo-icon"></div>
          <div class="pd-logo-div"></div>
          <span>CFG TWPO</span>
        </a>

        <nav class="pd-nav">
          <a href="/">Home</a>
          <a href="/catalog">Catálogo</a>
          <a href="/catalog">New Arrivals</a>
          <a href="#">Support</a>
        </nav>
      </div>
    </header>

    <!-- Breadcrumb -->
    <div class="pd-breadcrumb">
      <a href="/">Home</a>
      <span class="pd-breadcrumb-sep">/</span>
      <a href="/catalog">Catálogo</a>
      <span class="pd-breadcrumb-sep">/</span>
      <span>Detalles del Producto</span>
    </div>

    <!-- Product Details Container -->
    <div class="pd-container">
      <!-- Product Gallery -->
      <div class="pd-gallery">
        <div class="pd-gallery-main">
          <div class="pd-gallery-img"><img src={exhaustImage.src} alt="Titanium X-Pipe Exhaust" /></div>
          <span class="pd-tag pd-tag-green">Disponible</span>
        </div>
        <div class="pd-gallery-thumbs">
          <div class="pd-thumb pd-thumb-active"><img src={exhaustImage.src} alt="Exhaust" /></div>
          <div class="pd-thumb"><img src={turboImage.src} alt="Turbo" /></div>
          <div class="pd-thumb"><img src={pistonImage.src} alt="Piston" /></div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="pd-info">
        <div class="pd-category">Engine Components</div>
        <h1 class="pd-title">Titanium X-Pipe Exhaust</h1>
        <div class="pd-brand">TwPo Racing • Series 500</div>
        
        <div class="pd-rating">
          <div class="pd-stars">★★★★★</div>
          <span class="pd-rating-count">(5.0)</span>
          <span class="pd-reviews">128 reseñas</span>
        </div>

        <div class="pd-price">$1,299.00</div>

        <div class="pd-description">
          <p>Escape de alto rendimiento fabricado en titanio de grado aeroespacial. Diseñado para máxima flujo de gases y reducción de peso significativo.</p>
          <ul>
            <li>Fabricado en titanio grado 5 (Ti-6Al-4V)</li>
            <li>Incremento de potencia: 15-20 HP</li>
            <li>Reducción de peso: 40% vs acero inoxidable</li>
            <li>Garantía de por vida</li>
          </ul>
        </div>

        <div class="pd-actions">
          <div class="pd-quantity">
            <button class="pd-qty-btn">-</button>
            <input type="number" value="1" min="1" />
            <button class="pd-qty-btn">+</button>
          </div>
          <button class="pd-add-cart">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
            Agregar al Carrito
          </button>
        </div>

        <div class="pd-specs">
          <div class="pd-spec">
            <span class="pd-spec-label">SKU</span>
            <span class="pd-spec-value">TWR-XP-500</span>
          </div>
          <div class="pd-spec">
            <span class="pd-spec-label">Categoría</span>
            <span class="pd-spec-value">Escape</span>
          </div>
          <div class="pd-spec">
            <span class="pd-spec-label">Marca</span>
            <span class="pd-spec-value">TwPo Racing</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .pd-page { min-height: 100vh; background: #0d0d0d; color: #fff; font-family: 'Space Grotesk', sans-serif; }
  
  /* Header */
  .pd-header { background: #000; border-bottom: 1px solid rgba(255,255,255,.08); }
  .pd-header-inner { max-width: 1400px; margin: 0 auto; padding: 1rem 1.5rem; display: flex; align-items: center; gap: 2rem; }
  .pd-logo { display: flex; align-items: center; gap: .6rem; text-decoration: none; flex-shrink: 0; }
  .pd-logo-icon { width: 24px; height: 18px; background: #DF201A; clip-path: polygon(10% 0,90% 0,100% 100%,0 100%); }
  .pd-logo-div { width: 1px; height: 22px; background: rgba(255,255,255,.2); transform: rotate(12deg); }
  .pd-logo span { font-size: 1rem; font-weight: 700; letter-spacing: .06em; color: #fff; }
  .pd-nav { display: flex; gap: 1.5rem; }
  .pd-nav a { color: rgba(255,255,255,.5); text-decoration: none; font-weight: 600; transition: color .15s; }
  .pd-nav a:hover { color: #fff; }

  /* Breadcrumb */
  .pd-breadcrumb { max-width: 1400px; margin: 0 auto; padding: 1rem 1.5rem; display: flex; align-items: center; gap: .5rem; font-size: .85rem; }
  .pd-breadcrumb a { color: rgba(255,255,255,.5); text-decoration: none; }
  .pd-breadcrumb a:hover { color: #fff; }
  .pd-breadcrumb-sep { color: rgba(255,255,255,.3); }
  .pd-breadcrumb span:last-child { color: #fff; }

  /* Container */
  .pd-container { max-width: 1400px; margin: 0 auto; padding: 0 1.5rem 4rem; display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  @media (max-width: 900px) { .pd-container { grid-template-columns: 1fr; } }

  /* Gallery */
  .pd-gallery { display: flex; flex-direction: column; gap: 1rem; }
  .pd-gallery-main { position: relative; aspect-ratio: 4/3; border-radius: 12px; overflow: hidden; }
  .pd-gallery-img { position: absolute; inset: 0; }
  .pd-gallery-img img { width: 100%; height: 100%; object-fit: cover; }
  .pd-tag { position: absolute; top: 1rem; left: 1rem; font-size: .7rem; font-weight: 700; text-transform: uppercase; padding: .3rem .7rem; border-radius: 4px; }
  .pd-tag-green { background: #1ED838; color: #000; }
  .pd-gallery-thumbs { display: flex; gap: .75rem; }
  .pd-thumb { width: 80px; height: 60px; border-radius: 8px; cursor: pointer; opacity: .5; transition: opacity .15s; overflow: hidden; }
  .pd-thumb img { width: 100%; height: 100%; object-fit: cover; }
  .pd-thumb:hover, .pd-thumb-active { opacity: 1; }

  /* Info */
  .pd-info { display: flex; flex-direction: column; gap: 1.25rem; }
  .pd-category { font-size: .75rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: #E39B1D; }
  .pd-title { font-size: 2rem; font-weight: 700; line-height: 1.2; }
  .pd-brand { font-size: .9rem; color: rgba(255,255,255,.5); }
  .pd-rating { display: flex; align-items: center; gap: .5rem; }
  .pd-stars { color: #E39B1D; }
  .pd-rating-count { color: rgba(255,255,255,.7); }
  .pd-reviews { color: rgba(255,255,255,.4); font-size: .85rem; }
  .pd-price { font-size: 2rem; font-weight: 800; color: #fff; }
  .pd-description { color: rgba(255,255,255,.7); line-height: 1.6; }
  .pd-description ul { margin-top: .75rem; padding-left: 1.25rem; color: rgba(255,255,255,.5); }
  .pd-description li { margin-bottom: .5rem; }

  /* Actions */
  .pd-actions { display: flex; gap: 1rem; margin-top: 1rem; }
  .pd-quantity { display: flex; align-items: center; border: 1px solid rgba(255,255,255,.15); border-radius: 8px; overflow: hidden; }
  .pd-qty-btn { background: rgba(255,255,255,.05); border: none; color: #fff; width: 40px; height: 48px; cursor: pointer; font-size: 1.25rem; }
  .pd-qty-btn:hover { background: rgba(255,255,255,.1); }
  .pd-quantity input { width: 60px; background: none; border: none; color: #fff; text-align: center; font-size: 1rem; }
  .pd-add-cart { flex: 1; display: flex; align-items: center; justify-content: center; gap: .75rem; background: #DF201A; color: #fff; border: none; border-radius: 8px; font-weight: 700; cursor: pointer; transition: background .15s; }
  .pd-add-cart:hover { background: #c01b15; }
  .pd-add-cart svg { width: 18px; height: 18px; }

  /* Specs */
  .pd-specs { display: flex; gap: 2rem; margin-top: 1rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,.1); }
  .pd-spec { display: flex; flex-direction: column; gap: .25rem; }
  .pd-spec-label { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.4); }
  .pd-spec-value { font-size: .9rem; font-weight: 600; }
</style>
