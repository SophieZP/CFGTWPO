---
import MainLayout from '../layouts/MainLayout.astro';
import turboImage from '../assets/Turbocharger-008.jpg';
---

<MainLayout title="Twin-Scroll Turbo T4 - CFG TWPO" activePage="catalog">
  <!-- Product Details -->
  <div class="min-h-[calc(100vh-3.5rem)] bg-[#111] py-8 md:py-12">
    
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm mb-8">
        <a href="/" class="text-white/40 hover:text-white transition-colors">Home</a>
        <span class="text-white/20">/</span>
        <a href="/catalog" class="text-white/40 hover:text-white transition-colors">Catálogo</a>
        <span class="text-white/20">/</span>
        <span class="text-white">Twin-Scroll Turbo T4</span>
      </nav>

      <!-- Product Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        
        <!-- Image -->
        <div class="relative aspect-square bg-black rounded-xl overflow-hidden border border-white/08">
          <img 
            src={turboImage.src} 
            alt="Twin-Scroll Turbo T4"
            class="w-full h-full object-cover"
          />
          <span class="absolute top-4 left-4 bg-[#1ED838] text-black text-xs font-bold uppercase px-3 py-1 rounded">
            Disponible
          </span>
        </div>

        <!-- Info -->
        <div>
          <!-- Brand & Title -->
          <p class="text-sm text-[#E39B1D] font-semibold mb-2">TwPo Racing</p>
          <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-4">
            Twin-Scroll Turbo T4
          </h1>

          <!-- Rating -->
          <div class="flex items-center gap-3 mb-6">
            <div class="flex text-[#E39B1D] text-sm">
              {'★'.repeat(5)}
            </div>
            <span class="text-sm text-white5/40">(.0 · 128 reseñas)</span>
          </div>

          <!-- Price -->
          <div class="text-3xl md:text-4xl font-bold text-white mb-6">
            $1,299.00
          </div>

          <!-- Description -->
          <p class="text-white/60 leading-relaxed mb-8">
            Turbo de doble entrada T4 de alta rendimiento diseñado para aplicaciones de alto rendimiento. 
            Construido con materiales de grado aeroespacial para máxima durabilidad y respuesta.
          </p>

          <!-- Features -->
          <div class="space-y-3 mb-8">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#1ED838]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              <span class="text-white/70">Compresor de alta flujo</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#1ED838]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              <span class="text-white/70">Oil-cooled bearing assembly</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#1ED838]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              <span class="text-white/70">V-Band inlet y outlet</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#1ED838]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              <span class="text-white/70">Garrett GT Series geometry</span>
            </div>
          </div>

          <!-- Actions -->
          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <div class="flex items-center border border-white/20 rounded-lg overflow-hidden">
              <button class="px-4 py-3 text-white hover:bg-white/10 transition-colors">-</button>
              <input 
                type="number" 
                value="1" 
                class="w-16 text-center bg-transparent border-none outline-none text-white font-semibold"
              />
              <button class="px-4 py-3 text-white hover:bg-white/10 transition-colors">+</button>
            </div>
            <button class="flex-1 bg-[#DF201A] hover:bg-[#c01b15] text-white font-bold py-3 px-6 rounded-lg transition-colors flex items-center justify-center gap-2">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
              Agregar al Carrito
            </button>
          </div>

          <!-- Shipping Info -->
          <div class="bg-black border border-white/08 rounded-lg p-4 space-y-3">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
              <span class="text-sm text-white/70">Envío gratis en pedidos mayores a $500</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span class="text-sm text-white/70">Disponible en showroom</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23,4 23,10 17,10"/>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
              </svg>
              <span class="text-sm text-white/70">30 días para devoluciones</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Related Products -->
      <div class="mt-16">
        <h2 class="text-xl md:text-2xl font-bold text-white mb-6 border-l-4 border-[#DF201A] pl-4">
          Productos Relacionados
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            { name: 'Stage 2 Turbo Kit', price: '$2,100', image: 'turbo' },
            { name: 'High-Flow Intake', price: '$680', image: 'intake' },
            { name: 'Titanium Exhaust', price: '$1,299', image: 'exhaust' },
            { name: 'Carbon Air Filter', price: '$149', image: 'filter' },
          ].map((product) => (
            <a href="/productdetails" class="group bg-black border border-white/08 rounded-lg overflow-hidden hover:border-white/20 transition-colors">
              <div class="aspect-square bg-[#1a1a1a] flex items-center justify-center">
                <svg class="w-12 h-12 text-white/20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <circle cx="12" cy="12" r="10"/>
                  <path d="M12 16v-4M12 8h.01"/>
                </svg>
              </div>
              <div class="p-4">
                <h3 class="text-sm font-bold text-white group-hover:text-[#DF201A] transition-colors">{product.name}</h3>
                <p class="text-[#E39B1D] font-bold mt-1">{product.price}</p>
              </div>
            </a>
          ))}
        </div>
      </div>

    </div>
  </div>
</MainLayout>
