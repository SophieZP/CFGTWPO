---
import MainLayout from '../layouts/MainLayout.astro';

// Get redirect URL from query params
const redirect = Astro.url.searchParams.get('redirect') || '/';
---

<MainLayout title="Iniciar Sesión - CFG TWPO" activePage="login">
  <!-- Login Page -->
  <div class="min-h-[calc(100vh-3.5rem)] bg-[#111] flex items-center justify-center py-12">
    
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_50%_at_50%_50%,rgba(223,32,26,0.08)_0%,transparent_70%)]"></div>
    
    <!-- Content -->
    <div class="relative z-10 w-full max-w-md mx-auto px-4">
      
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-2">
          <div class="w-8 h-6 bg-[#DF201A] clip-polygon"></div>
          <div class="w-px h-6 bg-white/20 rotate-[12deg]"></div>
          <span class="text-lg font-bold tracking-wider text-white">CFG TWPO</span>
        </a>
      </div>
      
      <!-- Form Card -->
      <div class="bg-black border border-white/10 rounded-2xl p-8">
        <h1 class="text-2xl font-bold text-white mb-2">Bienvenido de nuevo</h1>
        <p class="text-white/50 mb-6">Inicia sesión para acceder a tu cuenta</p>
        
        <!-- Login Form -->
        <form id="login-form" class="space-y-4">
          <!-- Email -->
          <div>
            <label for="email" class="block text-sm font-medium text-white/70 mb-2">
              Correo electrónico
            </label>
            <input 
              type="email" 
              id="email" 
              name="email"
              required
              class="w-full bg-[#1a1a1a] border border-white/15 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-[#DF201A]/50 transition-colors"
              placeholder="tu@email.com"
            />
          </div>
          
          <!-- Password -->
          <div>
            <label for="password" class="block text-sm font-medium text-white/70 mb-2">
              Contraseña
            </label>
            <input 
              type="password" 
              id="password" 
              name="password"
              required
              class="w-full bg-[#1a1a1a] border border-white/15 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-[#DF201A]/50 transition-colors"
              placeholder="••••••••"
            />
          </div>
          
          <!-- Remember & Forgot -->
          <div class="flex items-center justify-between">
            <label class="flex items-center gap-2 cursor-pointer">
              <input 
                type="checkbox" 
                name="remember"
                class="w-4 h-4 accent-[#DF201A] rounded"
              />
              <span class="text-sm text-white/60">Recordarme</span>
            </label>
            <a href="#" class="text-sm text-[#E39B1D] hover:underline">
              ¿Olvidaste tu contraseña?
            </a>
          </div>
          
          <!-- Submit -->
          <button 
            type="submit"
            class="w-full bg-[#DF201A] hover:bg-[#c01b15] text-white font-bold py-3 px-6 rounded-lg transition-colors"
          >
            Iniciar Sesión
          </button>
        </form>
        
        <!-- Divider -->
        <div class="relative my-6">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-white/10"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-4 bg-black text-white/30">o</span>
          </div>
        </div>
        
        <!-- Demo Login -->
        <button 
          type="button"
          id="demo-login"
          class="w-full bg-white/08 hover:bg-white/12 text-white font-semibold py-3 px-6 rounded-lg border border-white/15 transition-colors"
        >
          Iniciar como Administrador (Demo)
        </button>
        
        <!-- Register Link -->
        <p class="text-center text-white/50 mt-6">
          ¿No tienes cuenta? 
          <a href="/register" class="text-[#E39B1D] hover:underline font-medium">
            Regístrate gratis
          </a>
        </p>
      </div>
      
      <!-- Back to Home -->
      <div class="text-center mt-6">
        <a href="/" class="inline-flex items-center gap-2 text-white/50 hover:text-white transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12,19 5,12 12,5"/>
          </svg>
          Volver al inicio
        </a>
      </div>
      
    </div>
  </div>
</MainLayout>

<script define:vars={{ redirect }}>
  import { login } from '../config/auth';
  
  const form = document.getElementById('login-form');
  const demoBtn = document.getElementById('demo-login');
  
  // Demo admin user
  const demoAdmin = {
    id: 'admin-001',
    email: 'admin@cfgtwpo.com',
    name: 'Administrador',
    role: 'admin',
    createdAt: new Date().toISOString(),
  };
  
  // Handle demo login
  demoBtn?.addEventListener('click', () => {
    // Simulate login
    login(demoAdmin, 'demo-token-12345');
    
    // Redirect
    const redirectUrl = new URL(redirect, window.location.origin);
    window.location.href = redirectUrl.pathname;
  });
  
  // Handle form submit
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    
    // For demo purposes, always log in as admin
    const email = document.getElementById('email')?.value;
    const password = document.getElementById('password')?.value;
    
    if (email && password) {
      login(demoAdmin, 'user-token-' + Date.now());
      
      // Redirect
      const redirectUrl = new URL(redirect, window.location.origin);
      window.location.href = redirectUrl.pathname;
    }
  });
</script>

<style>
  .clip-polygon {
    clip-path: polygon(10% 0, 90% 0, 100% 100%, 0 100%);
  }
</style>
