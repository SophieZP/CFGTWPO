---
import MainLayout from '../../layouts/MainLayout.astro';
import products from '../../data/products.json';

// Get product ID from URL
const { id } = Astro.params;

// Define a unified product type with all possible properties
interface UnifiedProduct {
  id: string;
  name: string;
  brand?: string;
  price: number;
  originalPrice?: number;
  rating?: number;
  reviews?: number;
  stock?: 'available' | 'preorder' | 'lowstock' | 'soldout';
  image: string;
  description?: string;
}

// Combine products from both sources with proper typing
const allProducts: UnifiedProduct[] = [
  ...products.map(p => ({ 
    id: p.id, 
    name: p.name, 
    brand: 'CFG Performance',
    price: p.price, 
    originalPrice: p.originalPrice,
    rating: p.rating,
    reviews: p.reviews,
    stock: 'available' as const,
    image: p.image,
    description: p.description
  })),
  {
    id: 'titanium-xpipe',
    name: 'Titanium X-Pipe Exhaust',
    brand: 'TwPo Racing',
    price: 1299.00,
    rating: 4,
    stock: 'available',
    image: 'Titanium Exhaust Tip-015.jpg',
    description: 'Escape de titanio X-Pipe de alto rendimiento.'
  },
  {
    id: 'coilover-kit',
    name: 'Coilover Kit Pro',
    brand: 'CFG Performance',
    price: 2450.00,
    rating: 5,
    stock: 'available',
    image: 'Suspension Kit-016.jpg',
    description: 'Kit de coilovers profesional para pista y calle.'
  },
  {
    id: 'carbon-steering',
    name: 'Carbon Fiber Steering Wheel',
    brand: 'TwPo Racing',
    price: 899.00,
    rating: 4,
    stock: 'preorder',
    image: 'Steering Wheel-017.jpg',
    description: 'Volante de fibra de carbono.'
  },
  {
    id: 'monoblock-wheels',
    name: 'Monoblock Forged Wheels 19"',
    brand: 'CFG Performance',
    price: 3200.00,
    rating: 3,
    stock: 'available',
    image: 'Alloy Wheel-018.jpg',
    description: 'Ruedas forjadas monoblock de 19 pulgadas.'
  },
  {
    id: 'digital-dashboard',
    name: 'Digital Racing Dashboard',
    brand: 'TwPo Racing',
    price: 1850.00,
    rating: 5,
    stock: 'available',
    image: 'Digital Dash-019.jpg',
    description: 'Panel digital de carreras.'
  },
  {
    id: 'turbocharger-stage2',
    name: 'Stage 2 Turbocharger Kit',
    brand: 'CFG Performance',
    price: 2100.00,
    rating: 5,
    stock: 'lowstock',
    image: 'Turbocharger-008.jpg',
    description: 'Kit turbocharger Stage 2.'
  },
  {
    id: 'intake-manifold',
    name: 'High-Flow Intake Manifold',
    brand: 'TwPo Racing',
    price: 680.00,
    rating: 4,
    stock: 'available',
    image: 'Engine block assembly-012.jpg',
    description: 'Multiple de admisión de alto flujo.'
  },
  {
    id: 'carbon-calipers',
    name: 'Carbon Brake Caliper Set',
    brand: 'CFG Performance',
    price: 1120.00,
    rating: 5,
    stock: 'available',
    image: 'Brake disc rotor-007.jpg',
    description: 'Juego de pinzas de freno de carbono.'
  },
];

// Find product by ID
const product = allProducts.find(p => p.id === id);

// If product not found, redirect to 404
if (!product) {
  return Astro.redirect('/404');
}

const formatPrice = (price: number): string => {
  return new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
  }).format(price);
};

const getStockClass = (stock?: string): string => {
  switch (stock) {
    case 'available':
      return 'bg-[#1ED838] text-black';
    case 'preorder':
      return 'bg-[#DF201A] text-white';
    case 'lowstock':
      return 'bg-white/15 text-white/70';
    case 'soldout':
      return 'bg-white/15 text-white/70';
    default:
      return 'bg-white/15 text-white/70';
  }
};

const getStockText = (stock?: string) => {
  switch (stock) {
    case 'available':
      return 'Disponible';
    case 'preorder':
      return 'Pre-orden';
    case 'lowstock':
      return 'Poco stock';
    case 'soldout':
      return 'Agotado';
    default:
      return 'Disponible';
  }
};

// Get related products
const relatedProducts = allProducts
  .filter(p => p.id !== id)
  .slice(0, 4);
---

<MainLayout title={`${product.name} - CFG TWPO`} activePage="catalog">
  <div class="min-h-[calc(100vh-3.5rem)] bg-[#111] py-8 md:py-12">
    
    <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm mb-8" aria-label="Breadcrumb">
        <a href="/" class="text-white/40 hover:text-white transition-colors">Home</a>
        <span class="text-white/20">/</span>
        <a href="/catalog" class="text-white/40 hover:text-white transition-colors">Catálogo</a>
        <span class="text-white/20">/</span>
        <span class="text-white">{product.name}</span>
      </nav>

      <!-- Product Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        
        <!-- Image -->
        <div class="relative aspect-square bg-black rounded-xl overflow-hidden border border-white/08">
          <img 
            src={`/assets/${product.image}`}
            alt={product.name}
            class="w-full h-full object-cover"
            loading="eager"
          />
          <span class={`absolute top-4 left-4 text-xs font-bold uppercase px-3 py-1 rounded ${getStockClass(product.stock)}`}>
            {getStockText(product.stock)}
          </span>
        </div>

        <!-- Info -->
        <div>
          <p class="text-sm text-[#E39B1D] font-semibold mb-2">{product.brand || 'CFG TWPO'}</p>
          <h1 class="text-2xl md:text-3xl lg:text-4xl font-bold text-white mb-4">
            {product.name}
          </h1>

          <div class="flex items-center gap-3 mb-6">
            <div class="flex text-[#E39B1D] text-sm">
              {'★'.repeat(product.rating || 5)}
              {'☆'.repeat(5 - (product.rating || 5))}
            </div>
            <span class="text-sm text-white/40">{product.rating || 5} · {(product.reviews || 128)} reseñas</span>
          </div>

          <div class="text-3xl md:text-4xl font-bold text-white mb-6">
            {formatPrice(product.price)}
            {product.originalPrice && product.originalPrice > product.price && (
              <span class="text-lg text-white/40 line-through ml-3">
                {formatPrice(product.originalPrice)}
              </span>
            )}
          </div>

          <p class="text-white/60 leading-relaxed mb-8">
            {product.description || `Producto de alto rendimiento diseñado para aplicaciones de alto rendimiento.`}
          </p>

          <div class="space-y-3 mb-8">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#1ED838]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              <span class="text-white/70">Alta calidad de materiales</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#1ED838]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              <span class="text-white/70">Diseño de alto rendimiento</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-[#1ED838]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="20,6 9,17 4,12"/>
              </svg>
              <span class="text-white/70">Garantía del fabricante</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 mb-8">
            <div class="flex items-center border border-white/20 rounded-lg overflow-hidden">
              <button 
                class="px-4 py-3 text-white hover:bg-white/10 transition-colors" 
                aria-label="Decrease quantity"
                data-quantity-decrease
              >-</button>
              <input 
                type="number" 
                value="1" 
                min="1"
                class="w-16 text-center bg-transparent border-none outline-none text-white font-semibold"
                aria-label="Quantity"
                data-quantity-input
              />
              <button 
                class="px-4 py-3 text-white hover:bg-white/10 transition-colors"
                aria-label="Increase quantity"
                data-quantity-increase
              >+</button>
            </div>
            <button 
              class="flex-1 bg-[#DF201A] hover:bg-[#c01b15] text-white font-bold py-3 px-6 rounded-lg transition-colors flex items-center justify-center gap-2"
              data-add-to-cart
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
              </svg>
              Agregar al Carrito
            </button>
          </div>

          <div class="bg-black border border-white/08 rounded-lg p-4 space-y-3">
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                <circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
              </svg>
              <span class="text-sm text-white/70">Envío gratis en pedidos mayores a $500</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span class="text-sm text-white/70">Disponible en showroom</span>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-white/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="23,4 23,10 17,10"/>
                <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/>
              </svg>
              <span class="text-sm text-white/70">30 días para devoluciones</span>
            </div>
          </div>
        </div>

      </div>

      {relatedProducts.length > 0 && (
        <div class="mt-16">
          <h2 class="text-xl md:text-2xl font-bold text-white mb-6 border-l-4 border-[#DF201A] pl-4">
            Productos Relacionados
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            {relatedProducts.map((related) => (
              <a 
                href={`/product/${related.id}`}
                class="group bg-black border border-white/08 rounded-lg overflow-hidden hover:border-white/20 transition-colors"
              >
                <div class="aspect-square bg-[#1a1a1a] flex items-center justify-center overflow-hidden">
                  <img 
                    src={`/assets/${related.image}`}
                    alt={related.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                  />
                </div>
                <div class="p-4">
                  <h3 class="text-sm font-bold text-white group-hover:text-[#DF201A] transition-colors">{related.name}</h3>
                  <p class="text-[#E39B1D] font-bold mt-1">{formatPrice(related.price)}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </div>
</MainLayout>

<script>
  // Quantity controls
  const quantityInput = document.querySelector<HTMLInputElement>('[data-quantity-input]');
  const decreaseBtn = document.querySelector('[data-quantity-decrease]');
  const increaseBtn = document.querySelector('[data-quantity-increase]');
  
  if (quantityInput && decreaseBtn && increaseBtn) {
    decreaseBtn.addEventListener('click', () => {
      const current = parseInt(quantityInput.value) || 1;
      if (current > 1) {
        quantityInput.value = String(current - 1);
      }
    });
    
    increaseBtn.addEventListener('click', () => {
      const current = parseInt(quantityInput.value) || 1;
      quantityInput.value = String(current + 1);
    });
  }
  
  // Add to cart
  const addToCartBtn = document.querySelector('[data-add-to-cart]');
  addToCartBtn?.addEventListener('click', () => {
    const btn = addToCartBtn as HTMLButtonElement;
    const originalText = btn.textContent;
    btn.textContent = '✓ Agregado';
    btn.classList.add('bg-[#1ED838]');
    btn.classList.remove('bg-[#DF201A]');
    
    setTimeout(() => {
      btn.textContent = originalText;
      btn.classList.remove('bg-[#1ED838]');
      btn.classList.add('bg-[#DF201A]');
    }, 2000);
  });
</script>
