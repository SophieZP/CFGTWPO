---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Página No Encontrada - CFG TWPO" activePage="404">
  <!-- 404 Not Found Page -->
  <div class="min-h-[calc(100vh-3.5rem)] bg-[#111] flex items-center justify-center">
    
    <!-- Background Effects -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_50%_50%_at_50%_50%,rgba(223,32,26,0.1)_0%,transparent_70%)]"></div>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,transparent_0%,#0d0d0d_100%)]"></div>
    
    <!-- Content -->
    <div class="relative z-10 max-w-2xl mx-auto px-4 text-center">
      
      <!-- Error Code -->
      <div class="mb-8">
        <span class="text-[10rem] md:text-[14rem] font-bold text-[#DF201A]/20 leading-none font-mono select-none">
          404
        </span>
      </div>
      
      <!-- Title -->
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-4 tracking-tight">
        Página No <span class="text-[#DF201A]">Encontrada</span>
      </h1>
      
      <!-- Description -->
      <p class="text-base md:text-lg text-white/50 mb-8 max-w-md mx-auto leading-relaxed">
        Lo sentimos, la página que estás buscando no existe o ha sido movida a otra ubicación.
      </p>
      
      <!-- Suggestions -->
      <div class="bg-black/50 border border-white/10 rounded-xl p-6 mb-8 backdrop-blur-sm">
        <h2 class="text-sm font-bold uppercase tracking-wider text-white/60 mb-4">
          Quizás estés buscando
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          <a 
            href="/" 
            class="inline-flex items-center gap-2 px-4 py-2 bg-white/08 hover:bg-white/12 text-white/80 hover:text-white border border-white/10 rounded-lg transition-all text-sm"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
              <polyline points="9,22 9,12 15,12 15,22"/>
            </svg>
            Inicio
          </a>
          <a 
            href="/catalog" 
            class="inline-flex items-center gap-2 px-4 py-2 bg-white/08 hover:bg-white/12 text-white/80 hover:text-white border border-white/10 rounded-lg transition-all text-sm"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"/>
              <rect x="14" y="3" width="7" height="7"/>
              <rect x="14" y="14" width="7" height="7"/>
              <rect x="3" y="14" width="7" height="7"/>
            </svg>
            Catálogo
          </a>
          <a 
            href="/catalog?category=motorcycles" 
            class="inline-flex items-center gap-2 px-4 py-2 bg-white/08 hover:bg-white/12 text-white/80 hover:text-white border border-white/10 rounded-lg transition-all text-sm"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="5" cy="17" r="3"/>
              <circle cx="19" cy="17" r="3"/>
              <path d="M5 17h4v-4h6v4h4l-3 6h-8l-3-6z"/>
            </svg>
            Motocicletas
          </a>
          <a 
            href="/catalog?category=cars" 
            class="inline-flex items-center gap-2 px-4 py-2 bg-white/08 hover:bg-white/12 text-white/80 hover:text-white border border-white/10 rounded-lg transition-all text-sm"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 17h14v-5H5v5z"/>
              <path d="M6 12l2-5h8l2 5"/>
              <circle cx="7" cy="17" r="2"/>
              <circle cx="17" cy="17" r="2"/>
            </svg>
            Carros
          </a>
        </div>
      </div>
      
      <!-- Search -->
      <form action="/catalog" method="get" class="max-w-md mx-auto">
        <div class="flex gap-2">
          <input 
            type="text" 
            name="search"
            placeholder="Buscar productos..." 
            class="flex-1 bg-black/50 border border-white/15 rounded-lg px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-[#DF201A]/50 transition-colors"
          />
          <button 
            type="submit"
            class="px-6 py-3 bg-[#DF201A] hover:bg-[#c01b15] text-white font-semibold rounded-lg transition-colors"
          >
            Buscar
          </button>
        </div>
      </form>
      
      <!-- Help -->
      <p class="text-sm text-white/35 mt-8">
        ¿Necesitas ayuda? <a href="/catalog" class="text-[#E39B1D] hover:underline">Contáctanos</a>
      </p>
      
    </div>
  </div>
</MainLayout>

<style>
  /* Subtle animation for the 404 text */
  span[text-^="10rem"] {
    animation: pulse 3s ease-in-out infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 0.15; }
    50% { opacity: 0.25; }
  }
</style>
