---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Estadísticas - CFG TWPO" activePage="stats">
  <!-- Stats Page -->
  <div class="min-h-[calc(100vh-3.5rem)] bg-[#111]">
    
    <!-- Page Header -->
    <div class="border-b border-white/[0.08] bg-gradient-to-r from-[#0a0c0e] via-[#121417] to-[#1a1d21] px-6 py-8 md:px-12 lg:px-20">
      <div class="max-w-[1400px] mx-auto">
        <div class="inline-flex items-center gap-2 bg-[rgba(223,32,26,0.12)] border border-[rgba(223,32,26,0.3)] rounded-full px-3 py-1 mb-5">
          <span class="w-2 h-2 rounded-full bg-[#1ED838] shadow-[0_0_8px_#1ED838]"></span>
          <span class="text-[0.7rem] font-bold uppercase tracking-widest text-white/50">Panel de Administración</span>
        </div>
        
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-3">
          <span class="text-white">Estadísticas </span>
          <span class="text-[#DF201A]">Dashboard</span>
        </h1>
        
        <p class="text-sm md:text-base text-white/50 max-w-[520px] leading-relaxed">
          Descripción del dashboard de estadísticas de CFG TWPO. Aquí podrás ver el rendimiento de tu tienda, ventas, y más métricas importantes.
        </p>

        <div class="flex flex-wrap gap-6 mt-6">
          <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-white/50">
            <span class="w-1.5 h-1.5 rounded-full bg-[#1ED838]"></span>
            Sistema Activo
          </div>
          <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-white/50">
            <span class="w-1.5 h-1.5 rounded-full bg-[#E39B1D]"></span>
            Última Actualización: Ahora
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-[1400px] mx-auto px-6 py-8 md:py-12 lg:px-20">
      
      <!-- Stats Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-10">
        
        <!-- Card 1: Total Revenue -->
        <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Ingresos Totales</span>
            <span class="text-[#1ED838] text-xs font-mono bg-[rgba(30,216,56,0.1)] px-2 py-0.5 rounded border border-[rgba(30,216,56,0.25)]">+12.5%</span>
          </div>
          <div class="text-2xl md:text-3xl font-bold text-white mb-1">$124,563</div>
          <div class="text-xs text-white/35">vs. $110,723 mes anterior</div>
        </div>

        <!-- Card 2: Orders -->
        <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Pedidos</span>
            <span class="text-[#1ED838] text-xs font-mono bg-[rgba(30,216,56,0.1)] px-2 py-0.5 rounded border border-[rgba(30,216,56,0.25)]">+8.2%</span>
          </div>
          <div class="text-2xl md:text-3xl font-bold text-white mb-1">1,284</div>
          <div class="text-xs text-white/35">vs. 1,187 mes anterior</div>
        </div>

        <!-- Card 3: Customers -->
        <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Clientes</span>
            <span class="text-[#E39B1D] text-xs font-mono bg-[rgba(227,155,29,0.1)] px-2 py-0.5 rounded border border-[rgba(227,155,29,0.25)]">+3.1%</span>
          </div>
          <div class="text-2xl md:text-3xl font-bold text-white mb-1">8,942</div>
          <div class="text-xs text-white/35">vs. 8,674 mes anterior</div>
        </div>

        <!-- Card 4: Conversion -->
        <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
          <div class="flex items-center justify-between mb-4">
            <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Conversión</span>
            <span class="text-[#DF201A] text-xs font-mono bg-[rgba(223,32,26,0.1)] px-2 py-0.5 rounded border border-[rgba(223,32,26,0.25)]">-2.4%</span>
          </div>
          <div class="text-2xl md:text-3xl font-bold text-white mb-1">3.24%</div>
          <div class="text-xs text-white/35">vs. 3.32% mes anterior</div>
        </div>

      </div>

      <!-- Charts Section -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">
        
        <!-- Sales Chart Placeholder -->
        <div class="bg-black border border-white/[0.07] rounded-xl p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-sm font-bold text-white">Ventas por Categoría</h3>
            <select class="bg-[#1a1a1a] border border-white/12 rounded px-2 py-1 text-xs text-white/60">
              <option>Últimos 30 días</option>
              <option>Últimos 90 días</option>
              <option>Último año</option>
            </select>
          </div>
          
          <!-- Simple Bar Chart -->
          <div class="flex items-end justify-between gap-2 h-48">
            {[
              { label: 'Motor', value: 85, color: 'bg-[#DF201A]' },
              { label: 'Escape', value: 72, color: 'bg-[#E39B1D]' },
              { label: 'Suspen.', value: 65, color: 'bg-[#1ED838]' },
              { label: 'Frenos', value: 58, color: 'bg-blue-500' },
              { label: 'Ruedas', value: 45, color: 'bg-purple-500' },
              { label: 'Otros', value: 30, color: 'bg-white/30' },
            ].map((item) => (
              <div class="flex flex-col items-center gap-2 flex-1">
                <div class="w-full bg-[#1a1a1a] rounded-t relative flex-1 flex items-end">
                  <div class={`w-full ${item.color} rounded-t transition-all duration-300`} style={`height: ${item.value}%`}></div>
                </div>
                <span class="text-[0.6rem] text-white/40 uppercase">{item.label}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Top Products -->
        <div class="bg-black border border-white/[0.07] rounded-xl p-6">
          <div class="flex items-center justify-between mb-6">
            <h3 class="text-sm font-bold text-white">Productos Populares</h3>
            <a href="/catalog" class="text-xs text-[#E39B1D] hover:underline">Ver todos</a>
          </div>
          
          <div class="space-y-4">
            {[
              { name: 'Turbo T4 Twin-Scroll', sales: 89, revenue: '$115,611' },
              { name: 'Coilover Kit Pro', sales: 67, revenue: '$164,150' },
              { name: 'Carbon Ceramic Rotor', sales: 54, revenue: '$24,300' },
              { name: 'Titanium Exhaust', sales: 43, revenue: '$55,857' },
              { name: 'Digital Dashboard', sales: 38, revenue: '$70,300' },
            ].map((product, i) => (
              <div class="flex items-center justify-between py-2 border-b border-white/05 last:border-0">
                <div class="flex items-center gap-3">
                  <span class="text-xs font-mono text-white/30 w-4">{i + 1}</span>
                  <div>
                    <div class="text-sm text-white">{product.name}</div>
                    <div class="text-xs text-white/35">{product.sales} ventas</div>
                  </div>
                </div>
                <span class="text-sm font-bold text-[#E39B1D]">{product.revenue}</span>
              </div>
            ))}
          </div>
        </div>

      </div>

      <!-- Recent Activity -->
      <div class="bg-black border border-white/[0.07] rounded-xl p-6">
        <h3 class="text-sm font-bold text-white mb-6">Actividad Reciente</h3>
        
        <div class="space-y-4">
          {[
            { time: '2 min', action: 'Nuevo pedido #1285', user: 'Carlos M.', amount: '$2,450.00', status: 'success' },
            { time: '15 min', action: 'Cliente registrado', user: 'María G.', amount: '-', status: 'info' },
            { time: '1 hora', action: 'Pedido #1284 enviado', user: 'Admin', amount: '$899.00', status: 'success' },
            { time: '3 horas', action: 'Stock bajo: Turbo T4', user: 'Sistema', amount: '-', status: 'warning' },
            { time: '5 horas', action: 'Nueva reseña recibida', user: 'Juan P.', amount: '★★★★★', status: 'info' },
          ].map((activity) => (
            <div class="flex items-center justify-between py-3 border-b border-white/05 last:border-0">
              <div class="flex items-center gap-4">
                <span class="text-xs text-white/30 font-mono whitespace-nowrap">{activity.time}</span>
                <div>
                  <div class="text-sm text-white">{activity.action}</div>
                  <div class="text-xs text-white/35">{activity.user}</div>
                </div>
              </div>
              <div class="text-right">
                <div class:list={[
                  'text-sm',
                  activity.amount === '-' ? 'text-white/50' : 'text-[#E39B1D] font-bold'
                ]}>
                  {activity.amount}
                </div>
                <div class:list={[
                  'text-xs',
                  activity.status === 'success' ? 'text-[#1ED838]' :
                  activity.status === 'warning' ? 'text-[#E39B1D]' :
                  'text-white/40'
                ]}>
                  {activity.status === 'success' && '✓ Completado'}
                  {activity.status === 'warning' && '⚠ Alerta'}
                  {activity.status === 'info' && 'ℹ Info'}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</MainLayout>
