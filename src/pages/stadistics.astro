---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Estadísticas - CFG TWPO" activePage="stats">
<div class="min-h-[calc(100vh-3.5rem)] bg-[#111]">
  
  <!-- Page Header -->
  <div class="border-b border-white/[0.08] bg-gradient-to-r from-[#0a0c0e] via-[#121417] to-[#1a1d21] px-6 py-8 md:px-12 lg:px-20" id="page-header">
    <div class="max-w-[1400px] mx-auto">
      <div class="inline-flex items-center gap-2 bg-[rgba(223,32,26,0.12)] border border-[rgba(223,32,3)] rounded-full26,0. px-3 py-1 mb-5">
        <span class="w-2 h-2 rounded-full bg-[#1ED838] shadow-[0_0_8px_#1ED838]"></span>
        <span class="text-[0.7rem] font-bold uppercase tracking-widest text-white/50">Panel de Administración</span>
      </div>
      
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold tracking-tight mb-3">
        <span class="text-white">Estadísticas </span>
        <span class="text-[#DF201A]">Dashboard</span>
      </h1>
      
      <p class="text-sm md:text-base text-white/50 max-w-[520px] leading-relaxed">
        Descripción del dashboard de estadísticas de CFG TWPO. Aquí podrás ver el rendimiento de tu tienda, ventas, y más métricas importantes.
      </p>

      <div class="flex flex-wrap gap-6 mt-6">
        <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-white/50">
          <span class="w-1.5 h-1.5 rounded-full bg-[#1ED838]"></span>
          Sistema Activo
        </div>
        <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-white/50">
          <span class="w-1.5 h-1.5 rounded-full bg-[#E39B1D]"></span>
          Última Actualización: Ahora
        </div>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="max-w-[1400px] mx-auto px-6 py-8 md:py-12 lg:px-20" id="main-content">
    
    <!-- Stats Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6 mb-10">
      
      <!-- Card 1: Total Revenue -->
      <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Ingresos Totales</span>
          <span class="text-[#1ED838] text-xs font-mono bg-[rgba(30,216,56,0.1)] px-2 py-0.5 rounded border border-[rgba(30,216,56,0.25)]">+12.5%</span>
        </div>
        <div class="text-2xl md:text-3xl font-bold text-white mb-1">$124,563</div>
        <div class="text-xs text-white/35">vs. $110,723 mes anterior</div>
      </div>

      <!-- Card 2: Orders -->
      <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Pedidos</span>
          <span class="text-[#1ED838] text-xs font-mono bg-[rgba(30,216,56,0.1)] px-2 py-0.5 rounded border border-[rgba(30,216,56,0.25)]">+8.2%</span>
        </div>
        <div class="text-2xl md:text-3xl font-bold text-white mb-1">1,284</div>
        <div class="text-xs text-white/35">vs. 1,187 mes anterior</div>
      </div>

      <!-- Card 3: Customers -->
      <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Clientes</span>
          <span class="text-[#E39B1D] text-xs font-mono bg-[rgba(227,155,29,0.1)] px-2 py-0.5 rounded border border-[rgba(227,155,29,0.25)]">+3.1%</span>
        </div>
        <div class="text-2xl md:text-3xl font-bold text-white mb-1">8,942</div>
        <div class="text-xs text-white/35">vs. 8,674 mes anterior</div>
      </div>

      <!-- Card 4: Conversion -->
      <div class="bg-black border border-white/[0.07] rounded-xl p-5 md:p-6">
        <div class="flex items-center justify-between mb-4">
          <span class="text-[0.7rem] font-bold uppercase tracking-wider text-white/40">Conversión</span>
          <span class="text-[#DF201A] text-xs font-mono bg-[rgba(223,32,26,0.1)] px-2 py-0.5 rounded border border-[rgba(223,32,26,0.25)]">-2.4%</span>
        </div>
        <div class="text-2xl md:text-3xl font-bold text-white mb-1">3.24%</div>
        <div class="text-xs text-white/35">vs. 3.32% mes anterior</div>
      </div>

    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">
      
      <!-- Sales Chart Placeholder -->
      <div class="bg-black border border-white/[0.07] rounded-xl p-6">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-sm font-bold text-white">Ventas por Categoría</h3>
          <select class="bg-[#1a1a1a] border border-white/12 rounded px-2 py-1 text-xs text-white/60">
            <option>Últimos 30 días</option>
            <option>Últimos 90 días</option>
            <option>Último año</option>
          </select>
        </div>
        
        <!-- Simple Bar Chart -->
        <div class="flex items-end justify-between gap-2 h-48">
          <div class="flex flex-col items-center gap-2 flex-1">
            <div class="w-full bg-[#1a1a1a] rounded-t relative flex-1 flex items-end h-full">
              <div class="w-full bg-[#DF201A] rounded-t" style="height: 85%"></div>
            </div>
            <span class="text-[0.6rem] text-white/40 uppercase">Motor</span>
          </div>
          <div class="flex flex-col items-center gap-2 flex-1">
            <div class="w-full bg-[#1a1a1a] rounded-t relative flex-1 flex items-end h-full">
              <div class="w-full bg-[#E39B1D] rounded-t" style="height: 72%"></div>
            </div>
            <span class="text-[0.6rem] text-white/40 uppercase">Escape</span>
          </div>
          <div class="flex flex-col items-center gap-2 flex-1">
            <div class="w-full bg-[#1a1a1a] rounded-t relative flex-1 flex items-end h-full">
              <div class="w-full bg-[#1ED838] rounded-t" style="height: 65%"></div>
            </div>
            <span class="text-[0.6rem] text-white/40 uppercase">Suspen.</span>
          </div>
          <div class="flex flex-col items-center gap-2 flex-1">
            <div class="w-full bg-[#1a1a1a] rounded-t relative flex-1 flex items-end h-full">
              <div class="w-full bg-blue-500 rounded-t" style="height: 58%"></div>
            </div>
            <span class="text-[0.6rem] text-white/40 uppercase">Frenos</span>
          </div>
          <div class="flex flex-col items-center gap-2 flex-1">
            <div class="w-full bg-[#1a1a1a] rounded-t relative flex-1 flex items-end h-full">
              <div class="w-full bg-purple-500 rounded-t" style="height: 45%"></div>
            </div>
            <span class="text-[0.6rem] text-white/40 uppercase">Ruedas</span>
          </div>
          <div class="flex flex-col items-center gap-2 flex-1">
            <div class="w-full bg-[#1a1a1a] rounded-t relative flex-1 flex items-end h-full">
              <div class="w-full bg-white/30 rounded-t" style="height: 30%"></div>
            </div>
            <span class="text-[0.6rem] text-white/40 uppercase">Otros</span>
          </div>
        </div>
      </div>

      <!-- Top Products -->
      <div class="bg-black border border-white/[0.07] rounded-xl p-6">
        <div class="flex items-center justify-between mb-6">
          <h3 class="text-sm font-bold text-white">Productos Populares</h3>
          <a href="/catalog" class="text-xs text-[#E39B1D] hover:underline">Ver todos</a>
        </div>
        
        <div class="space-y-4">
          <div class="flex items-center justify-between py-2 border-b border-white/05">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono text-white/30 w-4">1</span>
              <div>
                <div class="text-sm text-white">Turbo T4 Twin-Scroll</div>
                <div class="text-xs text-white/35">89 ventas</div>
              </div>
            </div>
            <span class="text-sm font-bold text-[#E39B1D]">$115,611</span>
          </div>
          <div class="flex items-center justify-between py-2 border-b border-white/05">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono text-white/30 w-4">2</span>
              <div>
                <div class="text-sm text-white">Coilover Kit Pro</div>
                <div class="text-xs text-white/35">67 ventas</div>
              </div>
            </div>
            <span class="text-sm font-bold text-[#E39B1D]">$164,150</span>
          </div>
          <div class="flex items-center justify-between py-2 border-b border-white/05">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono text-white/30 w-4">3</span>
              <div>
                <div class="text-sm text-white">Carbon Ceramic Rotor</div>
                <div class="text-xs text-white/35">54 ventas</div>
              </div>
            </div>
            <span class="text-sm font-bold text-[#E39B1D]">$24,300</span>
          </div>
          <div class="flex items-center justify-between py-2 border-b border-white/05">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono text-white/30 w-4">4</span>
              <div>
                <div class="text-sm text-white">Titanium Exhaust</div>
                <div class="text-xs text-white/35">43 ventas</div>
              </div>
            </div>
            <span class="text-sm font-bold text-[#E39B1D]">$55,857</span>
          </div>
          <div class="flex items-center justify-between py-2">
            <div class="flex items-center gap-3">
              <span class="text-xs font-mono text-white/30 w-4">5</span>
              <div>
                <div class="text-sm text-white">Digital Dashboard</div>
                <div class="text-xs text-white/35">38 ventas</div>
              </div>
            </div>
            <span class="text-sm font-bold text-[#E39B1D]">$70,300</span>
          </div>
        </div>
      </div>

    </div>

    <!-- Recent Activity -->
    <div class="bg-black border border-white/[0.07] rounded-xl p-6">
      <h3 class="text-sm font-bold text-white mb-6">Actividad Reciente</h3>
      
      <div class="space-y-4">
        <div class="flex items-center justify-between py-3 border-b border-white/05">
          <div class="flex items-center gap-4">
            <span class="text-xs text-white/30 font-mono whitespace-nowrap">2 min</span>
            <div>
              <div class="text-sm text-white">Nuevo pedido #1285</div>
              <div class="text-xs text-white/35">Carlos M.</div>
            </div>
          </div>
          <div class="text-right">
            <div class="text-sm text-[#E39B1D] font-bold">$2,450.00</div>
            <div class="text-xs text-[#1ED838]">✓ Completado</div>
          </div>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-white/05">
          <div class="flex items-center gap-4">
            <span class="text-xs text-white/30 font-mono whitespace-nowrap">15 min</span>
            <div>
              <div class="text-sm text-white">Cliente registrado</div>
              <div class="text-xs text-white/35">María G.</div>
            </div>
          </div>
          <div class="text-right">
            <div class="text-sm text-white/50">-</div>
            <div class="text-xs text-white/40">ℹ Info</div>
          </div>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-white/05">
          <div class="flex items-center gap-4">
            <span class="text-xs text-white/30 font-mono whitespace-nowrap">1 hora</span>
            <div>
              <div class="text-sm text-white">Pedido #1284 enviado</div>
              <div class="text-xs text-white/35">Admin</div>
            </div>
          </div>
          <div class="text-right">
            <div class="text-sm text-[#E39B1D] font-bold">$899.00</div>
            <div class="text-xs text-[#1ED838]">✓ Completado</div>
          </div>
        </div>
        <div class="flex items-center justify-between py-3 border-b border-white/05">
          <div class="flex items-center gap-4">
            <span class="text-xs text-white/30 font-mono whitespace-nowrap">3 horas</span>
            <div>
              <div class="text-sm text-white">Stock bajo: Turbo T4</div>
              <div class="text-xs text-white/35">Sistema</div>
            </div>
          </div>
          <div class="text-right">
            <div class="text-sm text-white/50">-</div>
            <div class="text-xs text-[#E39B1D]">⚠ Alerta</div>
          </div>
        </div>
        <div class="flex items-center justify-between py-3">
          <div class="flex items-center gap-4">
            <span class="text-xs text-white/30 font-mono whitespace-nowrap">5 horas</span>
            <div>
              <div class="text-sm text-white">Nueva reseña recibida</div>
              <div class="text-xs text-white/35">Juan P.</div>
            </div>
          </div>
          <div class="text-right">
            <div class="text-sm text-white/50">★★★★★</div>
            <div class="text-xs text-white/40">ℹ Info</div>
          </div>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  // Simple client-side auth check
  (function() {
    var token = localStorage.getItem('cfg_auth_token');
    var userStr = localStorage.getItem('cfg_auth_user');
    
    if (!token || !userStr) {
      showLoginRequired();
      return;
    }
    
    try {
      var user = JSON.parse(userStr);
      if (user.role !== 'admin') {
        showAccessDenied();
        return;
      }
    } catch (e) {
      showLoginRequired();
    }
  })();
  
  function showLoginRequired() {
    var header = document.getElementById('page-header');
    var mainContent = document.getElementById('main-content');
    
    if (header) {
      header.innerHTML = '<div class="flex flex-col items-center justify-center py-20"><svg class="w-16 h-16 text-white/20 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><h2 class="text-2xl font-bold text-white mb-2">Acceso Restringido</h2><p class="text-white/50 mb-6">Necesitas iniciar sesión para acceder a esta página.</p><a href="/login?redirect=/stadistics" class="bg-[#DF201A] hover:bg-[#c01b15] text-white font-bold py-3 px-6 rounded-lg transition-colors">Iniciar Sesión</a></div>';
    }
    
    if (mainContent) {
      mainContent.style.display = 'none';
    }
  }
  
  function showAccessDenied() {
    var header = document.getElementById('page-header');
    var mainContent = document.getElementById('main-content');
    
    if (header) {
      header.innerHTML = '<div class="flex flex-col items-center justify-center py-20"><svg class="w-16 h-16 text-white/20 mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/></svg><h2 class="text-2xl font-bold text-white mb-2">Acceso Denegado</h2><p class="text-white/50 mb-6">No tienes permisos de administrador para acceder a esta página.</p><a href="/" class="bg-[#DF201A] hover:bg-[#c01b15] text-white font-bold py-3 px-6 rounded-lg transition-colors">Volver al Inicio</a></div>';
    }
    
    if (mainContent) {
      mainContent.style.display = 'none';
    }
  }
</script>
</MainLayout>
