---
import SharedLayout from '../layouts/SharedLayout.astro';
---

<SharedLayout title="Estadísticas" activePage="support">
<div class="st-page">

  <div class="st-wrapper">

    <!-- ══ SIDEBAR ══ -->
    <aside class="st-sidebar">
      <div class="st-sidebar-inner">

        <div class="st-sidebar-brand">
          <div class="st-brand-avatar">C</div>
          <div>
            <div class="st-brand-name">CFG TWPO</div>
            <div class="st-brand-role">Admin Portal</div>
          </div>
        </div>

        <nav class="st-nav">
          <a href="#" class="st-nav-link st-nav-active">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
              <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
            </svg>
            Dashboard
          </a>
          <a href="#" class="st-nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2z"/>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
            </svg>
            Inventory
          </a>
          <a href="#" class="st-nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
            Orders
          </a>
          <a href="#" class="st-nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
            Customers
          </a>
          <a href="#" class="st-nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="18" y1="20" x2="18" y2="10"/>
              <line x1="12" y1="20" x2="12" y2="4"/>
              <line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
            Analytics
          </a>
        </nav>

        <div class="st-sidebar-footer">
          <a href="#" class="st-nav-link">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="3"/>
              <path d="M19.07 4.93A10 10 0 0 0 4.93 19.07M4.93 4.93A10 10 0 0 1 19.07 19.07"/>
            </svg>
            Settings
          </a>
          <div class="st-user">
            <div class="st-user-avatar">AR</div>
            <div>
              <div class="st-user-name">Alex Racer</div>
              <div class="st-user-role">Super Admin</div>
            </div>
          </div>
        </div>

      </div>
    </aside>

    <!-- ══ MAIN CONTENT ══ -->
    <main class="st-main">

      <!-- Top header bar -->
      <div class="st-topbar">
        <h2 class="st-page-title">Overview</h2>
        <div class="st-topbar-actions">
          <div class="st-topbar-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
            <input type="text" placeholder="Search orders, parts, or customers..." />
          </div>
          <div class="st-date-picker">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="15,18 9,12 15,6"/>
            </svg>
            <span>Oct 2023</span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="9,18 15,12 9,6"/>
            </svg>
            <button class="st-calendar-btn" aria-label="Abrir calendario">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </button>
          </div>
          <button class="st-notif-btn" aria-label="Notificaciones">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
              <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
            </svg>
            <span class="st-notif-dot"></span>
          </button>
        </div>
      </div>

      <div class="st-content">

        <!-- KPI Cards -->
        <div class="st-kpis">
          <div class="st-kpi">
            <div class="st-kpi-bg st-kpi-bg-red"></div>
            <div class="st-kpi-label">Total Revenue</div>
            <div class="st-kpi-value">$124,500</div>
            <div class="st-kpi-change st-change-up">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18,15 12,9 6,15"/></svg>
              <span>12%</span>
              <span class="st-kpi-period">vs last month</span>
            </div>
          </div>
          <div class="st-kpi">
            <div class="st-kpi-bg st-kpi-bg-gold"></div>
            <div class="st-kpi-label">Total Orders</div>
            <div class="st-kpi-value">1,240</div>
            <div class="st-kpi-change st-change-up">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18,15 12,9 6,15"/></svg>
              <span>5%</span>
              <span class="st-kpi-period">vs last month</span>
            </div>
          </div>
          <div class="st-kpi">
            <div class="st-kpi-bg st-kpi-bg-white"></div>
            <div class="st-kpi-label">Active Visitors</div>
            <div class="st-kpi-value">350</div>
            <div class="st-kpi-change st-change-down">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6,9 12,15 18,9"/></svg>
              <span>2%</span>
              <span class="st-kpi-period">vs last week</span>
            </div>
          </div>
          <div class="st-kpi">
            <div class="st-kpi-bg st-kpi-bg-gold"></div>
            <div class="st-kpi-label">Pending Shipments</div>
            <div class="st-kpi-value">45</div>
            <div class="st-kpi-change st-change-up">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18,15 12,9 6,15"/></svg>
              <span>8%</span>
              <span class="st-kpi-period">vs yesterday</span>
            </div>
          </div>
        </div>

        <!-- Charts Row -->
        <div class="st-charts-row">

          <!-- Sales Overview Chart -->
          <div class="st-card st-chart-card">
            <div class="st-card-header">
              <div>
                <div class="st-card-title">Sales Overview</div>
                <div class="st-card-subtitle">Revenue analytics across all channels</div>
              </div>
              <div class="st-toggle-group">
                <button class="st-toggle-btn st-toggle-active">Weekly</button>
                <button class="st-toggle-btn">Monthly</button>
                <button class="st-toggle-btn">Yearly</button>
              </div>
            </div>
            <div class="st-chart-area">
              <div class="st-chart-bars">
                <div class="st-bar-wrap" data-value="$4.2k">
                  <div class="st-bar" style="height: 55%;"></div>
                  <span class="st-bar-label">Mon</span>
                </div>
                <div class="st-bar-wrap" data-value="$6.8k">
                  <div class="st-bar st-bar-highlight" style="height: 72%;"></div>
                  <span class="st-bar-label">Tue</span>
                </div>
                <div class="st-bar-wrap" data-value="$5.1k">
                  <div class="st-bar" style="height: 60%;"></div>
                  <span class="st-bar-label">Wed</span>
                </div>
                <div class="st-bar-wrap" data-value="$8.4k">
                  <div class="st-bar st-bar-highlight" style="height: 88%;"></div>
                  <span class="st-bar-label">Thu</span>
                </div>
                <div class="st-bar-wrap" data-value="$6.2k">
                  <div class="st-bar" style="height: 66%;"></div>
                  <span class="st-bar-label">Fri</span>
                </div>
                <div class="st-bar-wrap" data-value="$7.9k">
                  <div class="st-bar" style="height: 80%;"></div>
                  <span class="st-bar-label">Sat</span>
                </div>
                <div class="st-bar-wrap" data-value="$9.5k">
                  <div class="st-bar st-bar-top" style="height: 100%;"></div>
                  <span class="st-bar-label">Sun</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Traffic Source Donut -->
          <div class="st-card st-donut-card">
            <div class="st-card-title">Traffic Source</div>
            <div class="st-donut-wrap">
              <svg class="st-donut-svg" viewBox="0 0 200 200">
                <!-- Background ring -->
                <circle cx="100" cy="100" r="70" fill="none" stroke="#27272a" stroke-width="28"/>
                <!-- Green 12% -->
                <circle cx="100" cy="100" r="70" fill="none" stroke="#1ED838" stroke-width="28"
                  stroke-dasharray="52.78 387.22" stroke-dashoffset="0"
                  transform="rotate(-90 100 100)"/>
                <!-- Gold 28% -->
                <circle cx="100" cy="100" r="70" fill="none" stroke="#E39B1D" stroke-width="28"
                  stroke-dasharray="123.15 317.85" stroke-dashoffset="-52.78"
                  transform="rotate(-90 100 100)"/>
                <!-- Red 60% -->
                <circle cx="100" cy="100" r="70" fill="none" stroke="#DF201A" stroke-width="28"
                  stroke-dasharray="263.89 176.11" stroke-dashoffset="-175.93"
                  transform="rotate(-90 100 100)"/>
              </svg>
              <div class="st-donut-center">
                <span class="st-donut-val">85%</span>
                <span class="st-donut-sub">Total Growth</span>
              </div>
            </div>
            <div class="st-traffic-legend">
              <div class="st-legend-item">
                <span class="st-legend-dot" style="background:#DF201A"></span>
                <span>Direct</span>
                <span class="st-legend-pct">60%</span>
              </div>
              <div class="st-legend-item">
                <span class="st-legend-dot" style="background:#E39B1D"></span>
                <span>Social</span>
                <span class="st-legend-pct">28%</span>
              </div>
              <div class="st-legend-item">
                <span class="st-legend-dot" style="background:#1ED838"></span>
                <span>Referral</span>
                <span class="st-legend-pct">12%</span>
              </div>
            </div>
          </div>

        </div>

        <!-- Bottom Row -->
        <div class="st-bottom-row">

          <!-- Recent Orders Table -->
          <div class="st-card st-orders-card">
            <div class="st-card-header">
              <div class="st-card-title">Recent Orders</div>
              <a href="#" class="st-link-red">View All</a>
            </div>
            <div class="st-table-wrap">
              <table class="st-table">
                <thead>
                  <tr>
                    <th>Order ID</th>
                    <th>Customer</th>
                    <th>Status</th>
                    <th class="st-th-right">Amount</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="st-td-mono">#ORD-0092</td>
                    <td>
                      <div class="st-customer">
                        <div class="st-avatar" style="background:#334155">JD</div>
                        John Doe
                      </div>
                    </td>
                    <td>
                      <span class="st-status st-status-green">
                        <span class="st-status-dot"></span>Delivered
                      </span>
                    </td>
                    <td class="st-td-right">$1,299.00</td>
                  </tr>
                  <tr>
                    <td class="st-td-mono">#ORD-0091</td>
                    <td>
                      <div class="st-customer">
                        <div class="st-avatar" style="background:#7f1d1d; color:#fca5a5">MS</div>
                        Mike Smith
                      </div>
                    </td>
                    <td>
                      <span class="st-status st-status-gold">
                        <span class="st-status-dot"></span>Processing
                      </span>
                    </td>
                    <td class="st-td-right">$850.50</td>
                  </tr>
                  <tr>
                    <td class="st-td-mono">#ORD-0090</td>
                    <td>
                      <div class="st-customer">
                        <div class="st-avatar" style="background:#312e81; color:#a5b4fc">AL</div>
                        Anna Lee
                      </div>
                    </td>
                    <td>
                      <span class="st-status st-status-green">
                        <span class="st-status-dot"></span>Delivered
                      </span>
                    </td>
                    <td class="st-td-right">$245.00</td>
                  </tr>
                  <tr>
                    <td class="st-td-mono">#ORD-0089</td>
                    <td>
                      <div class="st-customer">
                        <div class="st-avatar" style="background:#134e4a; color:#5eead4">RK</div>
                        Ryan King
                      </div>
                    </td>
                    <td>
                      <span class="st-status st-status-red">
                        <span class="st-status-dot"></span>Cancelled
                      </span>
                    </td>
                    <td class="st-td-right">$56.00</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Inventory Alerts -->
          <div class="st-card st-alerts-card">
            <div class="st-card-header">
              <div class="st-card-header-left">
                <svg viewBox="0 0 24 24" fill="none" stroke="#E39B1D" stroke-width="2" width="18" height="18">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                  <line x1="12" y1="9" x2="12" y2="13"/>
                  <line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
                <div class="st-card-title">Inventory Alerts</div>
              </div>
            </div>
            <div class="st-alerts-list">
              <div class="st-alert-item">
                <div class="st-alert-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <div class="st-alert-info">
                  <span class="st-alert-name">P-Zero Race Tires</span>
                  <span class="st-alert-sku">SKU: TR-2023-X</span>
                </div>
                <div class="st-alert-right">
                  <span class="st-badge st-badge-gold">Low Stock</span>
                  <span class="st-alert-count">5 Left</span>
                </div>
              </div>
              <div class="st-alert-item">
                <div class="st-alert-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <div class="st-alert-info">
                  <span class="st-alert-name">Carbon Brake Calipers</span>
                  <span class="st-alert-sku">SKU: BR-99-C</span>
                </div>
                <div class="st-alert-right">
                  <span class="st-badge st-badge-red">Out of Stock</span>
                  <span class="st-alert-count">0 Left</span>
                </div>
              </div>
              <div class="st-alert-item">
                <div class="st-alert-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <div class="st-alert-info">
                  <span class="st-alert-name">GT Racing Helmet</span>
                  <span class="st-alert-sku">SKU: HL-GT-01</span>
                </div>
                <div class="st-alert-right">
                  <span class="st-badge st-badge-gold">Low Stock</span>
                  <span class="st-alert-count">3 Left</span>
                </div>
              </div>
              <div class="st-alert-item">
                <div class="st-alert-icon">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                </div>
                <div class="st-alert-info">
                  <span class="st-alert-name">Front Bumper Kit</span>
                  <span class="st-alert-sku">SKU: BK-FR-22</span>
                </div>
                <div class="st-alert-right">
                  <span class="st-badge st-badge-gold">Low Stock</span>
                  <span class="st-alert-count">8 Left</span>
                </div>
              </div>
            </div>
            <div class="st-alerts-footer">
              <button class="st-restock-btn">Restock Inventory</button>
            </div>
          </div>

        </div>
      </div>
    </main>
  </div>

</div>
</SharedLayout>

<style>
  .st-page {
    background: #111;
    min-height: calc(100vh - 57px);
    font-family: 'Space Grotesk', sans-serif;
    color: #fff;
  }
  .st-wrapper {
    display: flex;
    min-height: calc(100vh - 57px);
  }

  /* ══ SIDEBAR ══ */
  .st-sidebar {
    width: 256px;
    flex-shrink: 0;
    background: #000;
    border-right: 1px solid rgba(255,255,255,.05);
  }
  .st-sidebar-inner {
    position: sticky;
    top: 57px;
    height: calc(100vh - 57px);
    display: flex;
    flex-direction: column;
    padding: 1.5rem 1rem;
    overflow-y: auto;
  }
  .st-sidebar-brand {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .5rem .5rem 1.75rem;
    border-bottom: 1px solid rgba(255,255,255,.05);
    margin-bottom: 1rem;
  }
  .st-brand-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: linear-gradient(135deg, #DF201A, #E39B1D);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .st-brand-name { font-size: .9rem; font-weight: 700; line-height: 1; margin-bottom: .2rem; }
  .st-brand-role { font-size: .72rem; color: rgba(255,255,255,.4); }
  .st-nav { flex: 1; display: flex; flex-direction: column; gap: .25rem; }
  .st-nav-link {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .7rem 1rem;
    border-radius: 8px;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    font-size: .88rem;
    font-weight: 500;
    transition: background .15s, color .15s;
  }
  .st-nav-link svg { width: 17px; height: 17px; flex-shrink: 0; }
  .st-nav-link:hover { background: rgba(255,255,255,.05); color: #fff; }
  .st-nav-active {
    background: #DF201A !important;
    color: #fff !important;
    box-shadow: 0 4px 20px rgba(223,32,26,.25);
  }
  .st-sidebar-footer {
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,.05);
    display: flex;
    flex-direction: column;
    gap: .5rem;
  }
  .st-user {
    display: flex;
    align-items: center;
    gap: .75rem;
    padding: .6rem 1rem;
  }
  .st-user-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,.12);
    border: 2px solid rgba(223,32,26,.5);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: .7rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .st-user-name { font-size: .85rem; font-weight: 600; line-height: 1; margin-bottom: .15rem; }
  .st-user-role { font-size: .7rem; color: rgba(255,255,255,.4); }

  /* ══ MAIN ══ */
  .st-main { flex: 1; min-width: 0; display: flex; flex-direction: column; }
  .st-topbar {
    background: rgba(17,17,17,.95);
    backdrop-filter: blur(4px);
    border-bottom: 1px solid rgba(255,255,255,.05);
    padding: .9rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    position: sticky;
    top: 57px;
    z-index: 10;
  }
  .st-page-title { font-size: 1.5rem; font-weight: 700; }
  .st-topbar-actions { display: flex; align-items: center; gap: .75rem; flex-wrap: wrap; }
  .st-topbar-search {
    display: flex;
    align-items: center;
    gap: .5rem;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 8px;
    padding: .5rem .75rem;
    width: 260px;
  }
  .st-topbar-search svg { width: 14px; height: 14px; color: rgba(255,255,255,.35); flex-shrink: 0; }
  .st-topbar-search input {
    background: none;
    border: none;
    outline: none;
    color: #fff;
    font-family: inherit;
    font-size: .82rem;
    flex: 1;
  }
  .st-topbar-search input::placeholder { color: rgba(255,255,255,.3); }
  .st-date-picker {
    display: flex;
    align-items: center;
    gap: .4rem;
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,.1);
    border-radius: 8px;
    padding: .45rem .75rem;
    font-size: .82rem;
    color: rgba(255,255,255,.7);
  }
  .st-date-picker svg { width: 12px; height: 12px; color: rgba(255,255,255,.4); }
  .st-calendar-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: rgba(255,255,255,.5);
    padding: .1rem;
    line-height: 0;
  }
  .st-calendar-btn svg { width: 14px; height: 14px; }
  .st-notif-btn {
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
