# Configuración de Git para líneas finales

# Auto detect text files and normalize line endings to LF
* text=auto

# Code
*.js eol=lf
*.ts eol=lf
*.jsx eol=lf
*.tsx eol=lf
*.json eol=lf
*.astro eol=lf
*.css eol=lf
*.html eol=lf
*.md eol=lf
*.yml eol=lf
*.yaml eol=lf

# Windows will not complain about line endings
*.sln text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.ttf binary
*.otf binary
*.db binary
